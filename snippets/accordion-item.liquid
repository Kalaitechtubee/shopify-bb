{%- comment -%}
  Snippet: accordion-item.liquid
  Usage: {% render 'accordion-item', question: 'Q', answer: 'A', open: false, index: forloop.index %}
{%- endcomment -%}

{%- assign is_open = open | default: false -%}
{%- assign item_id = 'bb-acc-' | append: index | append: '-' | append: section.id -%}

<div class="bb-accordion__item{% if is_open %} bb-accordion__item--open{% endif %}">
  <button
    class="bb-accordion__trigger"
    aria-expanded="{{ is_open }}"
    aria-controls="{{ item_id }}"
    type="button"
  >
    <span>{{ question }}</span>
    <span class="bb-accordion__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
    </span>
  </button>
  <div class="bb-accordion__content" id="{{ item_id }}" role="region">
    <p>{{ answer }}</p>
  </div>
</div>

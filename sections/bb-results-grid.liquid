{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}
{%- assign _bb_meta = product.metafields.custom.results.value -%}
{%- if section.blocks.size == 0 and _bb_meta == blank -%}{%- assign _skip_section = true -%}{%- endif -%}
{%- unless _skip_section -%}

{%- style -%}
  #bb-results-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 0 }}px;
    padding-left: {{ section.settings.padding_left_mobile | default: 0 }}px;
    padding-right: {{ section.settings.padding_right_mobile | default: 0 }}px;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
    
    /* CSS Variables mapping for complete customization */
    --results-bg: {{ section.settings.background_color }};
    --results-max-width: {{ section.settings.container_max_width }}px;
    
    --results-badge-bg: {{ section.settings.badge_bg_color }};
    --results-badge-text: {{ section.settings.badge_text_color }};
    --results-badge-border: {{ section.settings.badge_border_color }};
    --results-badge-radius: {{ section.settings.badge_border_radius }}px;
    --results-badge-size: {{ section.settings.badge_font_size }}px;
    --results-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --results-heading-size: {{ section.settings.heading_size_desktop }}px;
    --results-heading-weight: {{ section.settings.heading_weight }};
    --results-heading-color: {{ section.settings.heading_color }};
    --results-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --results-cols-desktop: {{ section.settings.columns_desktop }};
    --results-gap: {{ section.settings.grid_gap }}px;
    
    --results-card-bg: {{ section.settings.card_bg_color }};
    --results-card-border: {{ section.settings.card_border_color }};
    --results-card-border-hover: {{ section.settings.card_border_hover_color }};
    --results-card-radius: {{ section.settings.card_border_radius }}px;
    --results-card-padding: {{ section.settings.card_padding }}px;
    
    --results-bullet-size: {{ section.settings.bullet_size }}px;
    --results-bullet-color: {{ section.settings.bullet_color }};
    
    --results-card-title-size: {{ section.settings.card_title_size }}px;
    --results-card-title-weight: {{ section.settings.card_title_weight }};
    --results-card-title-color: {{ section.settings.card_title_color }};
    
    --results-card-desc-size: {{ section.settings.card_desc_size }}px;
    --results-card-desc-color: {{ section.settings.card_desc_color }};
  }
  @media (min-width: 768px) {
    #bb-results-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
      padding-left: {{ section.settings.padding_left | default: 0 }}px;
      padding-right: {{ section.settings.padding_right | default: 0 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-results-{{ section.id }} .bb-results-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }

  #bb-results-{{ section.id }} .bb-container {
    max-width: var(--results-max-width);
    width: 100%;
    
    {%- if section.settings.alignment == 'left' -%}
      margin-left: 0;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'center' -%}
      margin-left: auto;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'right' -%}
      margin-left: auto;
      margin-right: 0;
    {%- endif -%}
  }

  #bb-results-{{ section.id }} .bb-results-v2__inner {
    max-width: var(--results-max-width);
    width: 100%;
    margin-left: inherit;
    margin-right: inherit;
    
    {%- if section.settings.alignment == 'left' -%}
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    {%- elsif section.settings.alignment == 'center' -%}
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    {%- elsif section.settings.alignment == 'right' -%}
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      text-align: right;
    {%- endif -%}
  }

  #bb-results-{{ section.id }} .bb-results-v2__heading {
    text-align: inherit;
    width: 100%;
    margin-top: 0;
    line-height: 1.0;
    letter-spacing: -2px;
    color: #17123B;
  }
  #bb-results-{{ section.id }} .bb-results-v2__heading .bb-heading-maroon {
    color: #6B2430;
    display: block;
  }

  #bb-results-{{ section.id }} .bb-results-v2__grid {
    text-align: left;
  }
  #bb-results-{{ section.id }} .bb-results-v2__card:hover {
    border-color: var(--results-card-border-hover);
  }
{%- endstyle -%}

<section
  id="bb-results-{{ section.id }}"
  class="bb-section bb-results-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-results-v2__inner">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-results-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-results-v2__heading">
          {%- assign h_lower = section.settings.heading | downcase -%}
          {%- if h_lower contains "results women" and h_lower contains "within weeks" -%}
            {%- if h_lower contains " see " -%}
              {%- assign first_part = section.settings.heading | split: " see " | first -%}
              {%- assign second_part = section.settings.heading | split: first_part | last -%}
              {{ first_part }}<br><span class="bb-heading-maroon">{{ second_part | strip }}</span>
            {%- elsif h_lower contains " see " or h_lower contains " see " -%}
              {%- assign first_part = section.settings.heading | split: " see " | first -%}
              {%- assign second_part = section.settings.heading | split: first_part | last -%}
              {{ first_part }}<br><span class="bb-heading-maroon">{{ second_part | strip }}</span>
            {%- else -%}
              {{ section.settings.heading }}
            {%- endif -%}
          {%- else -%}
            {{ section.settings.heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}

      <!-- Results Grid -->
      <div class="bb-results-v2__grid">
        {%- if section.settings.use_default_content -%}
          <!-- 6 Default Cards to match reference image -->
          <div class="bb-results-v2__card bb-fade-in">
            <div class="bb-results-v2__card-title-wrap">
              <span class="bb-results-v2__card-bullet"></span>
              <h3 class="bb-results-v2__card-title">Reduced hair fall</h3>
            </div>
            <p class="bb-results-v2__card-desc">Follicle stimulation strengthens roots â€” shedding visibly reduces in weeks</p>
          </div>
          <div class="bb-results-v2__card bb-fade-in">
            <div class="bb-results-v2__card-title-wrap">
              <span class="bb-results-v2__card-bullet"></span>
              <h3 class="bb-results-v2__card-title">Baby hair regrowth</h3>
            </div>
            <p class="bb-results-v2__card-desc">New growth in thinning areas as dormant follicles reactivate</p>
          </div>
          <div class="bb-results-v2__card bb-fade-in">
            <div class="bb-results-v2__card-title-wrap">
              <span class="bb-results-v2__card-bullet"></span>
              <h3 class="bb-results-v2__card-title">Thicker, denser strands</h3>
            </div>
            <p class="bb-results-v2__card-desc">Deep nutrient delivery means each strand grows stronger from the root</p>
          </div>
          <div class="bb-results-v2__card bb-fade-in">
            <div class="bb-results-v2__card-title-wrap">
              <span class="bb-results-v2__card-bullet"></span>
              <h3 class="bb-results-v2__card-title">Healthier scalp</h3>
            </div>
            <p class="bb-results-v2__card-desc">Less dryness and irritation as blood flow and hydration improve</p>
          </div>
          <div class="bb-results-v2__card bb-fade-in">
            <div class="bb-results-v2__card-title-wrap">
              <span class="bb-results-v2__card-bullet"></span>
              <h3 class="bb-results-v2__card-title">Better from other treatments</h3>
            </div>
            <p class="bb-results-v2__card-desc">Enhanced absorption means your oils and serums finally work properly</p>
          </div>
          <div class="bb-results-v2__card bb-fade-in">
            <div class="bb-results-v2__card-title-wrap">
              <span class="bb-results-v2__card-bullet"></span>
              <h3 class="bb-results-v2__card-title">More confidence</h3>
            </div>
            <p class="bb-results-v2__card-desc">Visible density improvement in thinning areas and along the hairline</p>
          </div>
        {%- else -%}
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'result_card' -%}
                <div class="bb-results-v2__card bb-fade-in" {{ block.shopify_attributes }}>
                  
                  <!-- Optional Card Image -->
                  {%- if block.settings.image != blank -%}
                    <div class="bb-results-v2__card-img">
                      <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                    </div>
                  {%- endif -%}

                  <!-- Title Row -->
                  <div class="bb-results-v2__card-title-wrap">
                    {%- if block.settings.custom_bullet != blank -%}
                      <span class="bb-results-v2__card-icon" style="width:{{ section.settings.bullet_size }}px; height:{{ section.settings.bullet_size }}px; display:inline-block; flex-shrink:0;">
                        <img src="{{ block.settings.custom_bullet | image_url: width: 48 }}" alt="" loading="lazy" style="width:100%; height:100%; object-fit:contain;">
                      </span>
                    {%- else -%}
                      <span class="bb-results-v2__card-bullet"></span>
                    {%- endif -%}
                    <h3 class="bb-results-v2__card-title">{{ block.settings.title }}</h3>
                  </div>

                  <!-- Description -->
                  {%- if block.settings.description != blank -%}
                    <p class="bb-results-v2__card-desc">{{ block.settings.description }}</p>
                  {%- endif -%}

                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- assign results_meta = product.metafields.custom.result_images.value -%}
            {%- if results_meta != blank -%}
              {%- for item in results_meta -%}
                <div class="bb-results-v2__card bb-fade-in">
                  <div class="bb-results-v2__card-title-wrap">
                    <span class="bb-results-v2__card-bullet"></span>
                    <h3 class="bb-results-v2__card-title">{{ item.title }}</h3>
                  </div>
                  {%- if item.description != blank -%}
                    <p class="bb-results-v2__card-desc">{{ item.description }}</p>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- endunless -%}{%- comment -%}end _skip_section{%- endcomment -%}
{%- endunless -%}

{% schema %}

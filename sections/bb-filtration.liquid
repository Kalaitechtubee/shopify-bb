{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-filtration-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  #bb-filtration-{{ section.id }} .bb-heading    { color: {{ section.settings.heading_color }}; }
  #bb-filtration-{{ section.id }} .bb-subheading { color: {{ section.settings.accent_color }}; }
  #bb-filtration-{{ section.id }} .bb-body       { color: {{ section.settings.text_color }}; }
  @media (min-width: 768px) {
    #bb-filtration-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-filtration-{{ section.id }}"
  class="bb-section bb-filtration {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-filtration__inner {% if section.settings.image_position == 'right' %}bb-filtration__inner--reversed{% endif %}">

      <!-- Image -->
      <div class="bb-filtration__image bb-fade-in">
        {%- if section.settings.image != blank -%}
          <div class="bb-img-wrap bb-img-wrap--portrait">
            <img
              src="{{ section.settings.image | image_url: width: 900 }}"
              srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | escape | default: section.settings.heading | escape }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              loading="lazy"
            >
          </div>
        {%- else -%}
          <div class="bb-img-wrap bb-img-wrap--portrait" style="background:#f0f0f0;">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <!-- Text -->
      <div class="bb-filtration__text bb-fade-in">
        {%- if section.settings.subheading != blank -%}
          <p class="bb-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="bb-heading bb-heading--lg bb-mb-16">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body_text != blank -%}
          <div class="bb-body bb-mb-32">{{ section.settings.body_text }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="bb-checklist">
            {%- for block in section.blocks -%}
              {%- if block.type == 'filtration_point' -%}
                <li class="bb-checklist__item" {{ block.shopify_attributes }}>
                  {%- render 'icon-check', color: '#622229', size: 18 -%}
                  <span style="color:{{ section.settings.text_color }};">{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <div class="bb-mt-32">
            <a href="{{ section.settings.button_url | default: '#' }}" class="bb-btn bb-btn--primary">
              {{ section.settings.button_text }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  .bb-filtration__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .bb-filtration__inner--reversed {
    direction: rtl;
  }
  .bb-filtration__inner--reversed > * {
    direction: ltr;
  }
  @media (max-width: 768px) {
    .bb-filtration__inner {
      grid-template-columns: 1fr;
      direction: ltr;
    }
  }
</style>

{%- endunless -%}

{% schema %}
{
  "name": "BB Filtration",
  "tag": "section",
  "class": "bb-section-filtration",
  "settings": [
    {
      "type": "header",
      "content": "Section Control"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable Section",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Multi-Stage Filtration Technology"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body Text",
      "default": "<p>Splash uses a 5-stage filtration process to remove chlorine, heavy metals, and bacteria — while infusing your shower water with skin-loving vitamins.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Filtration Image / Diagram"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f8f8f8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#622229"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Mobile",
      "default": 26
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top — Desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom — Desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top — Mobile",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom — Mobile",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "filtration_point",
      "name": "Filtration Point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Point Text",
          "default": "Stage 1: KDF media removes chlorine & heavy metals"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BB Filtration",
      "blocks": [
        {
          "type": "filtration_point",
          "settings": {
            "text": "Stage 1: KDF media removes chlorine & heavy metals"
          }
        },
        {
          "type": "filtration_point",
          "settings": {
            "text": "Stage 2: Calcium sulfite removes residual chlorine"
          }
        },
        {
          "type": "filtration_point",
          "settings": {
            "text": "Stage 3: Vitamin C ball infuses shower water with antioxidants"
          }
        },
        {
          "type": "filtration_point",
          "settings": {
            "text": "Stage 4: Mineral ceramic balls balance pH level"
          }
        },
        {
          "type": "filtration_point",
          "settings": {
            "text": "Stage 5: Lavender-infused final filter for aromatherapy"
          }
        }
      ]
    }
  ]
}
{% endschema %}

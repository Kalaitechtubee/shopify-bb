{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #000000;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} {
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__slider {
    position: relative;
    width: 100%;
    height: {{ section.settings.hero_height_mobile | default: '70vh' }};
    min-height: 480px;
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__slider {
      height: {{ section.settings.hero_height_desktop | default: '85vh' }};
      min-height: 600px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), visibility 0.8s ease;
    z-index: 1;
  }

  #bb-hero-{{ section.id }} .bb-hero__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  /* Media Background (Image or Video) */
  #bb-hero-{{ section.id }} .bb-hero__media-wrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  #bb-hero-{{ section.id }} .bb-hero__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  #bb-hero-{{ section.id }} .bb-hero__media--mobile {
    display: block;
  }
  #bb-hero-{{ section.id }} .bb-hero__media--desktop {
    display: none;
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__media--mobile {
      display: none;
    }
    #bb-hero-{{ section.id }} .bb-hero__media--desktop {
      display: block;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__media--iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100vh;
    min-width: 177.77vh;
    transform: translate(-50%, -50%);
    pointer-events: none;
    border: none;
    display: block;
  }

  /* Overlay */
  #bb-hero-{{ section.id }} .bb-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.45) 100%);
    z-index: 2;
  }

  /* Content Overlay */
  #bb-hero-{{ section.id }} .bb-hero__content-container {
    position: relative;
    z-index: 3;
    height: 100%;
    max-width: {{ section.settings.container_max_width | default: 1320 }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 20px;
    padding-right: 20px;
    display: flex;
    align-items: center;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__content-container {
      padding-left: 40px;
      padding-right: 40px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__content-box {
    max-width: 780px;
    width: 100%;
  }

  #bb-hero-{{ section.id }} .bb-hero__content-box--left {
    text-align: left;
    margin-right: auto;
  }
  #bb-hero-{{ section.id }} .bb-hero__content-box--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  #bb-hero-{{ section.id }} .bb-hero__content-box--right {
    text-align: right;
    margin-left: auto;
  }

  /* Heading & Typography */
  #bb-hero-{{ section.id }} .bb-hero__title {
    font-family: var(--font-heading-family, system-ui, -apple-system, sans-serif);
    font-size: {{ section.settings.title_size_mobile | default: 36 }}px;
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1.1;
    margin: 0 0 16px 0;
    letter-spacing: -1px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__title {
      font-size: {{ section.settings.title_size_desktop | default: 68 }}px;
      margin-bottom: 20px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__title-highlight {
    color: {{ section.settings.highlight_color | default: '#A6FF00' }};
    font-style: italic;
    font-weight: 800;
    display: inline-block;
  }

  #bb-hero-{{ section.id }} .bb-hero__subtext {
    font-size: {{ section.settings.subtext_size_mobile | default: 16 }}px;
    font-weight: 400;
    color: #F0F0F0;
    line-height: 1.5;
    margin: 0 0 28px 0;
    max-width: 620px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__subtext {
      font-size: {{ section.settings.subtext_size_desktop | default: 20 }}px;
      margin-bottom: 36px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__content-box--center .bb-hero__subtext {
    margin-left: auto;
    margin-right: auto;
  }

  /* Button Styling */
  #bb-hero-{{ section.id }} .bb-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.btn_bg_color | default: '#A6FF00' }};
    color: {{ section.settings.btn_text_color | default: '#000000' }};
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 16px 36px;
    border-radius: {{ section.settings.btn_border_radius | default: 0 }}px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__btn {
      font-size: 16px;
      padding: 18px 44px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(166, 255, 0, 0.4);
  }

  /* Pagination & Indicator Styles */
  #bb-hero-{{ section.id }} .bb-hero__dots-wrap {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
  }

  #bb-hero-{{ section.id }} .bb-hero__dot {
    width: 10px;
    height: 10px;
    border-radius: 20px;
    background-color: rgba(255, 255, 255, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #bb-hero-{{ section.id }} .bb-hero__dot.is-active {
    width: 34px;
    background-color: {{ section.settings.highlight_color | default: '#A6FF00' }};
    border-color: {{ section.settings.highlight_color | default: '#A6FF00' }};
    box-shadow: 0 0 14px {{ section.settings.highlight_color | default: '#A6FF00' }};
  }

  /* Numbers Counter */
  #bb-hero-{{ section.id }} .bb-hero__numbers-wrap {
    position: absolute;
    bottom: 28px;
    right: 40px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 8px 18px;
    border-radius: 30px;
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
  }

  #bb-hero-{{ section.id }} .bb-hero__counter-btn {
    background: transparent;
    border: none;
    color: #FFFFFF;
    font-size: 18px;
    cursor: pointer;
    line-height: 1;
    padding: 0 4px;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  #bb-hero-{{ section.id }} .bb-hero__counter-btn:hover {
    color: {{ section.settings.highlight_color | default: '#A6FF00' }};
    transform: scale(1.25);
  }

  #bb-hero-{{ section.id }} .bb-hero__current-num {
    color: {{ section.settings.highlight_color | default: '#A6FF00' }};
    font-weight: 700;
  }

  /* Side Navigation Arrows */
  #bb-hero-{{ section.id }} .bb-hero__nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #FFFFFF;
    font-size: 22px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #bb-hero-{{ section.id }} .bb-hero__nav-arrow--prev {
    left: 24px;
  }

  #bb-hero-{{ section.id }} .bb-hero__nav-arrow--next {
    right: 24px;
  }

  #bb-hero-{{ section.id }} .bb-hero__nav-arrow:hover {
    background: {{ section.settings.highlight_color | default: '#A6FF00' }};
    color: #000000;
    border-color: {{ section.settings.highlight_color | default: '#A6FF00' }};
    box-shadow: 0 0 15px {{ section.settings.highlight_color | default: '#A6FF00' }};
  }

  /* Progress Bar Lines */
  #bb-hero-{{ section.id }} .bb-hero__progress-bar-wrap {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 40px);
    max-width: 900px;
    z-index: 10;
    display: flex;
    gap: 14px;
    align-items: center;
    justify-content: center;
  }

  #bb-hero-{{ section.id }} .bb-hero__progress-item {
    flex: 1;
    height: 6px;
    background-color: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    position: relative;
    box-sizing: border-box;
  }

  #bb-hero-{{ section.id }} .bb-hero__progress-item:hover {
    background-color: rgba(0, 0, 0, 0.6);
  }

  #bb-hero-{{ section.id }} .bb-hero__progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background-color: #FFFFFF;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.95);
    border-radius: 4px;
    transition: none;
  }

  #bb-hero-{{ section.id }} .bb-hero__progress-item.is-completed .bb-hero__progress-fill {
    width: 100%;
    transition: none;
  }
{%- endstyle -%}

<section
  id="bb-hero-{{ section.id }}"
  class="bb-section bb-hero {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-interval="{{ section.settings.autoplay_interval | default: 5 | times: 1000 }}"
>
  <div class="bb-hero__slider">
    {%- for block in section.blocks -%}
      <div
        class="bb-hero__slide {% if forloop.first %}is-active{% endif %}"
        data-slide-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        <!-- Background Media (Image, Video, or Custom Color) -->
        <div class="bb-hero__media-wrap">
          {%- if block.settings.bg_color != blank and block.settings.image == blank and block.settings.video == blank and block.settings.video_url_mp4 == blank -%}
            <div class="bb-hero__media" style="background: {{ block.settings.bg_color }};"></div>
          {%- elsif block.settings.video != blank -%}
            {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'bb-hero__media bb-hero__media--desktop' }}
            {%- if block.settings.video_mobile != blank -%}
              {{ block.settings.video_mobile | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'bb-hero__media bb-hero__media--mobile' }}
            {%- else -%}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'bb-hero__media bb-hero__media--mobile' }}
            {%- endif -%}
          {%- elsif block.settings.video_url_mp4 != blank -%}
            {%- assign v_url = block.settings.video_url_mp4 -%}
            {%- if v_url contains 'youtu.be' or v_url contains 'youtube.com' -%}
              {%- if v_url contains 'youtu.be/' -%}
                {%- assign yt_id = v_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first -%}
              {%- elsif v_url contains 'v=' -%}
                {%- assign yt_id = v_url | split: 'v=' | last | split: '&' | first | split: '?' | first -%}
              {%- else -%}
                {%- assign yt_id = v_url | split: '/' | last | split: '?' | first -%}
              {%- endif -%}
              <iframe
                src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&controls=0&loop=1&playlist={{ yt_id }}&playsinline=1&enablejsapi=1&rel=0"
                class="bb-hero__media bb-hero__media--iframe"
                frameborder="0"
                allow="autoplay; encrypted-media"
                allowfullscreen
              ></iframe>
            {%- else -%}
              <video autoplay muted loop playsinline class="bb-hero__media bb-hero__media--desktop">
                <source src="{{ block.settings.video_url_mp4 }}" type="video/mp4">
              </video>
              {%- if block.settings.video_url_mp4_mobile != blank -%}
                <video autoplay muted loop playsinline class="bb-hero__media bb-hero__media--mobile">
                  <source src="{{ block.settings.video_url_mp4_mobile }}" type="video/mp4">
                </video>
              {%- else -%}
                <video autoplay muted loop playsinline class="bb-hero__media bb-hero__media--mobile">
                  <source src="{{ block.settings.video_url_mp4 }}" type="video/mp4">
                </video>
              {%- endif -%}
            {%- endif -%}
          {%- elsif block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 2200 }}"
              srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1400 }} 1400w, {{ block.settings.image | image_url: width: 2200 }} 2200w"
              sizes="100vw"
              alt="{{ block.settings.heading | escape | default: shop.name }}"
              class="bb-hero__media bb-hero__media--desktop"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ block.settings.image.width | default: 1920 }}"
              height="{{ block.settings.image.height | default: 1080 }}"
            >
            {%- if block.settings.image_mobile != blank -%}
              <img
                src="{{ block.settings.image_mobile | image_url: width: 1000 }}"
                srcset="{{ block.settings.image_mobile | image_url: width: 500 }} 500w, {{ block.settings.image_mobile | image_url: width: 1000 }} 1000w"
                sizes="100vw"
                alt="{{ block.settings.heading | escape | default: shop.name }}"
                class="bb-hero__media bb-hero__media--mobile"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ block.settings.image_mobile.width | default: 750 }}"
                height="{{ block.settings.image_mobile.height | default: 1000 }}"
              >
            {%- else -%}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.heading | escape | default: shop.name }}"
                class="bb-hero__media bb-hero__media--mobile"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ block.settings.image.width | default: 1920 }}"
                height="{{ block.settings.image.height | default: 1080 }}"
              >
            {%- endif -%}
          {%- else -%}
            <div class="bb-hero__media" style="background: {{ block.settings.bg_color | default: 'linear-gradient(135deg, #1A1A1A 0%, #333333 100%)' }};"></div>
          {%- endif -%}
        </div>

        <!-- Dark Gradient Overlay -->
        <div
          class="bb-hero__overlay"
          style="opacity: {{ block.settings.overlay_opacity | default: 40 | divided_by: 100.0 }};"
        ></div>

        <!-- Content Container -->
        <div
          class="bb-hero__content-container"
          style="align-items: {% case block.settings.content_position_vertical %}{% when 'top' %}flex-start{% when 'bottom' %}flex-end{% else %}center{% endcase %}; padding-top: {% if block.settings.content_position_vertical == 'top' %}80px{% else %}0{% endif %}; padding-bottom: {% if block.settings.content_position_vertical == 'bottom' %}80px{% else %}0{% endif %};"
        >
          <div class="bb-hero__content-box bb-hero__content-box--{{ block.settings.content_alignment | default: 'left' }}">
            {%- if block.settings.heading != blank -%}
              {%- assign h_color = block.settings.highlight_color | default: section.settings.highlight_color | default: '#A6FF00' -%}
              <h2 class="bb-hero__title">
                {%- if block.settings.heading contains '[' and block.settings.heading contains ']' -%}
                  {%- assign title_parts = block.settings.heading | split: '[' -%}
                  {{ title_parts[0] }}
                  {%- assign sub_parts = title_parts[1] | split: ']' -%}
                  <span class="bb-hero__title-highlight" style="color: {{ h_color }};">{{ sub_parts[0] }}</span>
                  {{ sub_parts[1] }}
                {%- else -%}
                  {%- if block.settings.highlight_text != blank -%}
                    <span class="bb-hero__title-highlight" style="color: {{ h_color }};">{{ block.settings.highlight_text }}</span>
                  {%- endif -%}
                  {{ block.settings.heading }}
                {%- endif -%}
              </h2>
            {%- endif -%}

            {%- if block.settings.subtext != blank -%}
              <p class="bb-hero__subtext">{{ block.settings.subtext }}</p>
            {%- endif -%}

            {%- if block.settings.button_text != blank -%}
              {%- assign b_bg = block.settings.btn_bg_color | default: section.settings.btn_bg_color | default: '#A6FF00' -%}
              {%- assign b_text = block.settings.btn_text_color | default: section.settings.btn_text_color | default: '#000000' -%}
              {%- assign b_rad = block.settings.btn_border_radius | default: section.settings.btn_border_radius | default: 0 -%}
              <a
                href="{{ block.settings.button_link | default: '#' }}"
                class="bb-hero__btn"
                style="background-color: {{ b_bg }}; color: {{ b_text }}; border-radius: {{ b_rad }}px;"
              >
                {{ block.settings.button_text }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}

    <!-- Slider Pagination & Navigation Indicators -->
    {%- if section.blocks.size > 1 -%}
      {%- assign p_style = section.settings.pagination_style -%}
      {%- if p_style == blank or p_style == '' -%}
        {%- assign p_style = 'dots' -%}
      {%- endif -%}

      {%- if p_style == 'dots' -%}
        <!-- Capsule Pill Dots Pagination -->
        <div class="bb-hero__dots-wrap" aria-label="Hero slider pagination">
          {%- for block in section.blocks -%}
            <div
              class="bb-hero__dot {% if forloop.first %}is-active{% endif %}"
              data-target-slide="{{ forloop.index0 }}"
              role="button"
              tabindex="0"
              aria-label="Go to slide {{ forloop.index }}"
            ></div>
          {%- endfor -%}
        </div>

      {%- elsif p_style == 'numbers' -%}
        <!-- Number Counter Pagination -->
        <div class="bb-hero__numbers-wrap" aria-label="Hero slider pagination">
          <button class="bb-hero__counter-btn bb-hero__btn-prev" aria-label="Previous slide">&#8249;</button>
          <span class="bb-hero__counter-text">
            <span class="bb-hero__current-num">01</span> / <span class="bb-hero__total-num">0{{ section.blocks.size }}</span>
          </span>
          <button class="bb-hero__counter-btn bb-hero__btn-next" aria-label="Next slide">&#8250;</button>
        </div>

      {%- elsif p_style == 'arrows' -%}
        <!-- Side Navigation Arrows -->
        <button class="bb-hero__nav-arrow bb-hero__nav-arrow--prev bb-hero__btn-prev" aria-label="Previous slide">&#8249;</button>
        <button class="bb-hero__nav-arrow bb-hero__nav-arrow--next bb-hero__btn-next" aria-label="Next slide">&#8250;</button>

      {%- elsif p_style == 'lines' -%}
        <!-- Progress Line Indicators -->
        <div class="bb-hero__progress-bar-wrap" aria-label="Hero slider pagination">
          {%- for block in section.blocks -%}
            <div
              class="bb-hero__progress-item {% if forloop.first %}is-active{% endif %}"
              data-target-slide="{{ forloop.index0 }}"
              role="button"
              tabindex="0"
              aria-label="Go to slide {{ forloop.index }}"
            >
              <div class="bb-hero__progress-fill"></div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<!-- Slider Logic Script -->
<script>
  (function () {
    function initHeroSlider() {
      var section = document.getElementById('bb-hero-{{ section.id }}');
      if (!section) return;

      var slides = section.querySelectorAll('.bb-hero__slide');
      if (slides.length <= 1) return;

      var progressItems = section.querySelectorAll('.bb-hero__progress-item');
      var dots          = section.querySelectorAll('.bb-hero__dot');
      var counterEl     = section.querySelector('.bb-hero__current-num');

      var isAutoplay   = section.getAttribute('data-autoplay') !== 'false';
      var intervalMs   = parseInt(section.getAttribute('data-interval'), 10) || 5000;

      var currentIndex = 0;
      var timer        = null;

      // ── Helper: reset a single fill bar ─────────────────────────────────
      function resetFill(fill) {
        fill.style.transition = 'none';
        fill.style.width      = '0%';
      }

      // ── Helper: animate a fill bar from 0 → 100% ────────────────────────
      function animateFill(fill) {
        resetFill(fill);
        // Wait one tick so the browser commits the 0% reset before animating
        setTimeout(function () {
          fill.style.transition = 'width ' + intervalMs + 'ms linear';
          fill.style.width      = '100%';
        }, 30);
      }

      // ── Go to a specific slide ───────────────────────────────────────────
      function goToSlide(next) {
        if (timer) clearTimeout(timer);

        // Slides
        slides.forEach(function (slide, i) {
          slide.classList.toggle('is-active', i === next);
        });

        // Progress lines
        progressItems.forEach(function (item, i) {
          var fill = item.querySelector('.bb-hero__progress-fill');
          item.classList.remove('is-active', 'is-completed');

          if (!fill) return;

          if (i < next) {
            // Already visited: instantly full
            item.classList.add('is-completed');
            fill.style.transition = 'none';
            fill.style.width      = '100%';
          } else if (i === next) {
            // Current: animate
            item.classList.add('is-active');
            animateFill(fill);
          } else {
            // Upcoming: instantly empty
            fill.style.transition = 'none';
            fill.style.width      = '0%';
          }
        });

        // Dots
        dots.forEach(function (dot, i) {
          dot.classList.toggle('is-active', i === next);
        });

        // Number counter
        if (counterEl) {
          var n = next + 1;
          counterEl.textContent = n < 10 ? '0' + n : '' + n;
        }

        currentIndex = next;

        // Auto-advance
        if (isAutoplay) {
          timer = setTimeout(function () {
            goToSlide((currentIndex + 1) % slides.length);
          }, intervalMs);
        }
      }

      // ── Click handlers ───────────────────────────────────────────────────
      progressItems.forEach(function (item, i) {
        item.addEventListener('click', function () { goToSlide(i); });
      });

      dots.forEach(function (dot, i) {
        dot.addEventListener('click', function () { goToSlide(i); });
      });

      section.querySelectorAll('.bb-hero__btn-prev').forEach(function (btn) {
        btn.addEventListener('click', function () {
          goToSlide((currentIndex - 1 + slides.length) % slides.length);
        });
      });

      section.querySelectorAll('.bb-hero__btn-next').forEach(function (btn) {
        btn.addEventListener('click', function () {
          goToSlide((currentIndex + 1) % slides.length);
        });
      });

      // ── Swipe support ────────────────────────────────────────────────────
      var touchStartX = 0;
      section.addEventListener('touchstart', function (e) {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      section.addEventListener('touchend', function (e) {
        var diff = touchStartX - e.changedTouches[0].screenX;
        if (Math.abs(diff) > 50) {
          goToSlide(diff > 0
            ? (currentIndex + 1) % slides.length
            : (currentIndex - 1 + slides.length) % slides.length);
        }
      }, { passive: true });

      // ── Start ────────────────────────────────────────────────────────────
      goToSlide(0);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroSlider);
    } else {
      initHeroSlider();
    }
    document.addEventListener('shopify:section:load', initHeroSlider);
  })();
</script>


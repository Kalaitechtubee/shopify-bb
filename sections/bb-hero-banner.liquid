{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #000000;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} {
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__slider {
    position: relative;
    width: 100%;
    height: {{ section.settings.hero_height_mobile | default: '70vh' }};
    min-height: 480px;
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__slider {
      height: {{ section.settings.hero_height_desktop | default: '85vh' }};
      min-height: 600px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), visibility 0.8s ease;
    z-index: 1;
  }

  #bb-hero-{{ section.id }} .bb-hero__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  /* Media Background (Image or Video) */
  #bb-hero-{{ section.id }} .bb-hero__media-wrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  #bb-hero-{{ section.id }} .bb-hero__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  #bb-hero-{{ section.id }} .bb-hero__media--mobile {
    display: block;
  }
  #bb-hero-{{ section.id }} .bb-hero__media--desktop {
    display: none;
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__media--mobile {
      display: none;
    }
    #bb-hero-{{ section.id }} .bb-hero__media--desktop {
      display: block;
    }
  }

  /* Overlay */
  #bb-hero-{{ section.id }} .bb-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.45) 100%);
    z-index: 2;
  }

  /* Content Overlay */
  #bb-hero-{{ section.id }} .bb-hero__content-container {
    position: relative;
    z-index: 3;
    height: 100%;
    max-width: {{ section.settings.container_max_width | default: 1320 }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 20px;
    padding-right: 20px;
    display: flex;
    align-items: center;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__content-container {
      padding-left: 40px;
      padding-right: 40px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__content-box {
    max-width: 780px;
    width: 100%;
  }

  #bb-hero-{{ section.id }} .bb-hero__content-box--left {
    text-align: left;
    margin-right: auto;
  }
  #bb-hero-{{ section.id }} .bb-hero__content-box--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  #bb-hero-{{ section.id }} .bb-hero__content-box--right {
    text-align: right;
    margin-left: auto;
  }

  /* Heading & Typography */
  #bb-hero-{{ section.id }} .bb-hero__title {
    font-family: var(--font-heading-family, system-ui, -apple-system, sans-serif);
    font-size: {{ section.settings.title_size_mobile | default: 36 }}px;
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1.1;
    margin: 0 0 16px 0;
    letter-spacing: -1px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__title {
      font-size: {{ section.settings.title_size_desktop | default: 68 }}px;
      margin-bottom: 20px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__title-highlight {
    color: {{ section.settings.highlight_color | default: '#A6FF00' }};
    font-style: italic;
    font-weight: 800;
    display: inline-block;
  }

  #bb-hero-{{ section.id }} .bb-hero__subtext {
    font-size: {{ section.settings.subtext_size_mobile | default: 16 }}px;
    font-weight: 400;
    color: #F0F0F0;
    line-height: 1.5;
    margin: 0 0 28px 0;
    max-width: 620px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__subtext {
      font-size: {{ section.settings.subtext_size_desktop | default: 20 }}px;
      margin-bottom: 36px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__content-box--center .bb-hero__subtext {
    margin-left: auto;
    margin-right: auto;
  }

  /* Button Styling */
  #bb-hero-{{ section.id }} .bb-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.btn_bg_color | default: '#A6FF00' }};
    color: {{ section.settings.btn_text_color | default: '#000000' }};
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 16px 36px;
    border-radius: {{ section.settings.btn_border_radius | default: 0 }}px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }

  @media (min-width: 768px) {
    #bb-hero-{{ section.id }} .bb-hero__btn {
      font-size: 16px;
      padding: 18px 44px;
    }
  }

  #bb-hero-{{ section.id }} .bb-hero__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(166, 255, 0, 0.4);
  }

  /* Progress Bar Indicators at Bottom */
  #bb-hero-{{ section.id }} .bb-hero__progress-bar-wrap {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 40px);
    max-width: 900px;
    z-index: 4;
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: center;
  }

  #bb-hero-{{ section.id }} .bb-hero__progress-item {
    flex: 1;
    height: 4px;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
    overflow: hidden;
    cursor: pointer;
    position: relative;
    transition: background-color 0.3s ease;
  }

  #bb-hero-{{ section.id }} .bb-hero__progress-item:hover {
    background-color: rgba(255, 255, 255, 0.5);
  }

  #bb-hero-{{ section.id }} .bb-hero__progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background-color: #FFFFFF;
    border-radius: 2px;
  }

  #bb-hero-{{ section.id }}[data-autoplay="true"] .bb-hero__progress-item.is-active .bb-hero__progress-fill {
    animation: bbProgressFill {{ section.settings.autoplay_interval | default: 5 }}s linear forwards;
  }

  #bb-hero-{{ section.id }} .bb-hero__progress-item.is-completed .bb-hero__progress-fill {
    width: 100% !important;
    animation: none !important;
    background-color: rgba(255, 255, 255, 0.9);
  }

  @keyframes bbProgressFill {
    from {
      width: 0%;
    }
    to {
      width: 100%;
    }
  }
{%- endstyle -%}

<section
  id="bb-hero-{{ section.id }}"
  class="bb-section bb-hero {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-interval="{{ section.settings.autoplay_interval | default: 5 | times: 1000 }}"
>
  <div class="bb-hero__slider">
    {%- for block in section.blocks -%}
      <div
        class="bb-hero__slide {% if forloop.first %}is-active{% endif %}"
        data-slide-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        <!-- Background Media (Image, Video, or Custom Color) -->
        <div class="bb-hero__media-wrap">
          {%- if block.settings.bg_color != blank and block.settings.image == blank and block.settings.video == blank and block.settings.video_url_mp4 == blank -%}
            <div class="bb-hero__media" style="background: {{ block.settings.bg_color }};"></div>
          {%- elsif block.settings.video != blank -%}
            {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'bb-hero__media bb-hero__media--desktop' }}
            {%- if block.settings.video_mobile != blank -%}
              {{ block.settings.video_mobile | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'bb-hero__media bb-hero__media--mobile' }}
            {%- else -%}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'bb-hero__media bb-hero__media--mobile' }}
            {%- endif -%}
          {%- elsif block.settings.video_url_mp4 != blank -%}
            <video autoplay muted loop playsinline class="bb-hero__media bb-hero__media--desktop">
              <source src="{{ block.settings.video_url_mp4 }}" type="video/mp4">
            </video>
            {%- if block.settings.video_url_mp4_mobile != blank -%}
              <video autoplay muted loop playsinline class="bb-hero__media bb-hero__media--mobile">
                <source src="{{ block.settings.video_url_mp4_mobile }}" type="video/mp4">
              </video>
            {%- else -%}
              <video autoplay muted loop playsinline class="bb-hero__media bb-hero__media--mobile">
                <source src="{{ block.settings.video_url_mp4 }}" type="video/mp4">
              </video>
            {%- endif -%}
          {%- elsif block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 2200 }}"
              srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1400 }} 1400w, {{ block.settings.image | image_url: width: 2200 }} 2200w"
              sizes="100vw"
              alt="{{ block.settings.heading | escape | default: shop.name }}"
              class="bb-hero__media bb-hero__media--desktop"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ block.settings.image.width | default: 1920 }}"
              height="{{ block.settings.image.height | default: 1080 }}"
            >
            {%- if block.settings.image_mobile != blank -%}
              <img
                src="{{ block.settings.image_mobile | image_url: width: 1000 }}"
                srcset="{{ block.settings.image_mobile | image_url: width: 500 }} 500w, {{ block.settings.image_mobile | image_url: width: 1000 }} 1000w"
                sizes="100vw"
                alt="{{ block.settings.heading | escape | default: shop.name }}"
                class="bb-hero__media bb-hero__media--mobile"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ block.settings.image_mobile.width | default: 750 }}"
                height="{{ block.settings.image_mobile.height | default: 1000 }}"
              >
            {%- else -%}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.heading | escape | default: shop.name }}"
                class="bb-hero__media bb-hero__media--mobile"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ block.settings.image.width | default: 1920 }}"
                height="{{ block.settings.image.height | default: 1080 }}"
              >
            {%- endif -%}
          {%- else -%}
            <div class="bb-hero__media" style="background: {{ block.settings.bg_color | default: 'linear-gradient(135deg, #1A1A1A 0%, #333333 100%)' }};"></div>
          {%- endif -%}
        </div>

        <!-- Dark Gradient Overlay -->
        <div
          class="bb-hero__overlay"
          style="opacity: {{ block.settings.overlay_opacity | default: 40 | divided_by: 100.0 }};"
        ></div>

        <!-- Content Container -->
        <div
          class="bb-hero__content-container"
          style="align-items: {% case block.settings.content_position_vertical %}{% when 'top' %}flex-start{% when 'bottom' %}flex-end{% else %}center{% endcase %}; padding-top: {% if block.settings.content_position_vertical == 'top' %}80px{% else %}0{% endif %}; padding-bottom: {% if block.settings.content_position_vertical == 'bottom' %}80px{% else %}0{% endif %};"
        >
          <div class="bb-hero__content-box bb-hero__content-box--{{ block.settings.content_alignment | default: 'left' }}">
            {%- if block.settings.heading != blank -%}
              {%- assign h_color = block.settings.highlight_color | default: section.settings.highlight_color | default: '#A6FF00' -%}
              <h2 class="bb-hero__title">
                {%- if block.settings.heading contains '[' and block.settings.heading contains ']' -%}
                  {%- assign title_parts = block.settings.heading | split: '[' -%}
                  {{ title_parts[0] }}
                  {%- assign sub_parts = title_parts[1] | split: ']' -%}
                  <span class="bb-hero__title-highlight" style="color: {{ h_color }};">{{ sub_parts[0] }}</span>
                  {{ sub_parts[1] }}
                {%- else -%}
                  {%- if block.settings.highlight_text != blank -%}
                    <span class="bb-hero__title-highlight" style="color: {{ h_color }};">{{ block.settings.highlight_text }}</span>
                  {%- endif -%}
                  {{ block.settings.heading }}
                {%- endif -%}
              </h2>
            {%- endif -%}

            {%- if block.settings.subtext != blank -%}
              <p class="bb-hero__subtext">{{ block.settings.subtext }}</p>
            {%- endif -%}

            {%- if block.settings.button_text != blank -%}
              {%- assign b_bg = block.settings.btn_bg_color | default: section.settings.btn_bg_color | default: '#A6FF00' -%}
              {%- assign b_text = block.settings.btn_text_color | default: section.settings.btn_text_color | default: '#000000' -%}
              {%- assign b_rad = block.settings.btn_border_radius | default: section.settings.btn_border_radius | default: 0 -%}
              <a
                href="{{ block.settings.button_link | default: '#' }}"
                class="bb-hero__btn"
                style="background-color: {{ b_bg }}; color: {{ b_text }}; border-radius: {{ b_rad }}px;"
              >
                {{ block.settings.button_text }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}

    <!-- Progress Line Indicators at Bottom -->
    {%- if section.blocks.size > 1 -%}
      <div class="bb-hero__progress-bar-wrap" aria-label="Hero slider pagination">
        {%- for block in section.blocks -%}
          <div
            class="bb-hero__progress-item {% if forloop.first %}is-active{% endif %}"
            data-target-slide="{{ forloop.index0 }}"
            role="button"
            tabindex="0"
            aria-label="Go to slide {{ forloop.index }}"
          >
            <div class="bb-hero__progress-fill"></div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<!-- Slider Logic Script -->
<script>
  (function () {
    function initHeroSlider() {
      const heroSection = document.getElementById('bb-hero-{{ section.id }}');
      if (!heroSection) return;

      const slides = heroSection.querySelectorAll('.bb-hero__slide');
      const progressItems = heroSection.querySelectorAll('.bb-hero__progress-item');
      const isAutoplay = heroSection.dataset.autoplay === 'true';
      const intervalTime = parseInt(heroSection.dataset.interval, 10) || 5000;

      let currentIndex = 0;
      let animFrameId = null;
      let startTime = null;

      if (slides.length <= 1) return;

      function goToSlide(nextIndex) {
        if (animFrameId) cancelAnimationFrame(animFrameId);

        slides[currentIndex].classList.remove('is-active');
        slides[nextIndex].classList.add('is-active');

        progressItems.forEach((item, idx) => {
          item.classList.remove('is-active', 'is-completed');
          const fill = item.querySelector('.bb-hero__progress-fill');
          if (idx < nextIndex) {
            item.classList.add('is-completed');
            if (fill) fill.style.width = '100%';
          } else if (idx > nextIndex) {
            if (fill) fill.style.width = '0%';
          } else {
            item.classList.add('is-active');
            if (fill) fill.style.width = '0%';
          }
        });

        currentIndex = nextIndex;

        if (isAutoplay) {
          startProgressLoop();
        }
      }

      function startProgressLoop() {
        if (animFrameId) cancelAnimationFrame(animFrameId);
        startTime = performance.now();

        const activeItem = progressItems[currentIndex];
        const activeFill = activeItem ? activeItem.querySelector('.bb-hero__progress-fill') : null;

        function animateProgress(now) {
          const elapsed = now - startTime;
          const progress = Math.min(100, (elapsed / intervalTime) * 100);

          if (activeFill) {
            activeFill.style.width = progress + '%';
          }

          if (progress >= 100) {
            const nextIdx = (currentIndex + 1) % slides.length;
            goToSlide(nextIdx);
          } else {
            animFrameId = requestAnimationFrame(animateProgress);
          }
        }

        animFrameId = requestAnimationFrame(animateProgress);
      }

      // Progress Line Click Handler
      progressItems.forEach((item, idx) => {
        item.addEventListener('click', function () {
          goToSlide(idx);
        });
      });

      // Touch Swipe Support
      let touchStartX = 0;
      let touchEndX = 0;

      heroSection.addEventListener('touchstart', function (e) {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });

      heroSection.addEventListener('touchend', function (e) {
        touchEndX = e.changedTouches[0].screenX;
        if (touchStartX - touchEndX > 50) {
          goToSlide((currentIndex + 1) % slides.length);
        } else if (touchEndX - touchStartX > 50) {
          goToSlide((currentIndex - 1 + slides.length) % slides.length);
        }
      }, { passive: true });

      // Initial state
      goToSlide(0);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroSlider);
    } else {
      initHeroSlider();
    }
    document.addEventListener('shopify:section:load', initHeroSlider);
  })();
</script>

{%- endunless -%}

{% schema %}
{
  "name": "BB Hero Banner Slider",
  "tag": "section",
  "class": "bb-section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Section Controls"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable Section",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1320
    },
    {
      "type": "header",
      "content": "Slider Height & Speed"
    },
    {
      "type": "select",
      "id": "hero_height_desktop",
      "label": "Slider Height (Desktop)",
      "options": [
        { "value": "60vh", "label": "Compact (60vh)" },
        { "value": "75vh", "label": "Medium (75vh)" },
        { "value": "85vh", "label": "Tall (85vh)" },
        { "value": "100vh", "label": "Full Screen (100vh)" }
      ],
      "default": "85vh"
    },
    {
      "type": "select",
      "id": "hero_height_mobile",
      "label": "Slider Height (Mobile)",
      "options": [
        { "value": "55vh", "label": "Compact (55vh)" },
        { "value": "70vh", "label": "Medium (70vh)" },
        { "value": "85vh", "label": "Tall (85vh)" },
        { "value": "100vh", "label": "Full Screen (100vh)" }
      ],
      "default": "70vh"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable Auto-Play Slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Auto-Slide Speed (Seconds)",
      "default": 5
    },
    {
      "type": "header",
      "content": "Typography & Colors"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlighted Text Color",
      "default": "#A6FF00"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "CTA Button Background Color",
      "default": "#A6FF00"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "CTA Button Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "btn_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "CTA Button Border Radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 28,
      "max": 90,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 68
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 24,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtext_size_desktop",
      "min": 14,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Subtext Size (Desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "subtext_size_mobile",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Subtext Size (Mobile)",
      "default": 16
    },
    {
      "type": "header",
      "content": "Section Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Margin Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide_video",
      "name": "Video Banner Slide",
      "settings": [
        {
          "type": "header",
          "content": "Background Video"
        },
        {

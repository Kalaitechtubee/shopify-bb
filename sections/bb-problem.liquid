      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1280
    },
    {
      "type": "header",
      "content": "Subheading Badge Options"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Badge Text",
      "default": "THE REAL PROBLEM"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#FAF0F0"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#622229"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Badge Border Color",
      "default": "#FAF0F0"
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Badge Border Radius",
      "default": 50
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Badge Font Size",
      "default": 11
    },
    {
      "type": "range",
      "id": "badge_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Badge Margin Bottom",
      "default": 26
    },
    {
      "type": "header",
      "content": "Heading Options"
    },
    {
      "type": "text",
      "id": "heading",

{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-problem-{{ section.id }} {
    background-color: {{ section.settings.section_background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    
    --problem-max-width: {{ section.settings.container_max_width }}px;
    --problem-badge-bg: {{ section.settings.badge_bg_color }};
    --problem-badge-text: {{ section.settings.badge_text_color }};
    --problem-badge-radius: {{ section.settings.badge_border_radius }}px;
    --problem-badge-size: {{ section.settings.badge_font_size }}px;
    --problem-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --problem-heading-size: {{ section.settings.heading_size_desktop }}px;
    --problem-heading-weight: {{ section.settings.heading_weight }};
    --problem-heading-color: {{ section.settings.heading_color }};
    --problem-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --problem-panel-bg: {{ section.settings.panel_bg_color }};
    --problem-panel-radius: {{ section.settings.panel_border_radius }}px;
    --problem-panel-padding-desktop: {{ section.settings.panel_padding_desktop }}px;
    --problem-panel-margin: {{ section.settings.panel_margin_bottom }}px;
    
    --problem-quote-size: {{ section.settings.quote_size }}px;
    --problem-quote-color: {{ section.settings.quote_color }};
    --problem-quote-margin: {{ section.settings.quote_margin_bottom }}px;
    
    --problem-list-gap: {{ section.settings.list_gap }}px;
    --problem-item-size: {{ section.settings.item_font_size }}px;
    --problem-item-color: {{ section.settings.item_text_color }};
    
    --problem-icon-size: {{ section.settings.icon_size }}px;
    --problem-icon-bg: {{ section.settings.icon_bg_color }};
    --problem-icon-color: {{ section.settings.icon_symbol_color }};
    
    --problem-alert-bg: {{ section.settings.alert_bg_color }};
    --problem-alert-border-color: {{ section.settings.alert_border_color }};
    --problem-alert-border-width: {{ section.settings.alert_border_width }}px;
    --problem-alert-size: {{ section.settings.alert_font_size }}px;
    --problem-alert-color: {{ section.settings.alert_text_color }};
    --problem-alert-highlight-color: {{ section.settings.alert_highlight_color }};
    --problem-alert-padding: {{ section.settings.alert_padding_y }}px {{ section.settings.alert_padding_x }}px;
  }
  @media (min-width: 768px) {
    #bb-problem-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-problem-{{ section.id }} .bb-problem-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
    #bb-problem-{{ section.id }} .bb-problem-v2__panel {
      padding: {{ section.settings.panel_padding_mobile }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-problem-{{ section.id }}"
  class="bb-section bb-problem-section-wrapper {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-problem-v2">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-problem-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading — two-color split: navy line 1, maroon line 2 -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-problem-v2__heading">
          Hair fall isn't about<br>
          <span class="bb-heading-maroon">weak hair. It's a lazy scalp.</span>
        </h2>
      {%- endif -%}

      <!-- Dark Panel Box -->
      <div class="bb-problem-v2__panel bb-fade-in">
        <!-- Quote with left accent bar -->
        {%- if section.settings.quote_text != blank -%}
          <div class="bb-problem-v2__quote-wrap">
            <div class="bb-problem-v2__quote-bar"></div>
            <p class="bb-problem-v2__quote">{{ section.settings.quote_text }}</p>
          </div>
        {%- endif -%}

        <!-- Problem Checklist Items -->
        {%- if section.blocks.size > 0 -%}
          <ul class="bb-problem-v2__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'problem_item' -%}
                <li class="bb-problem-v2__list-item" {{ block.shopify_attributes }}>
                  <span class="bb-problem-v2__icon">
                    {%- if block.settings.custom_icon != blank -%}
                      <img src="{{ block.settings.custom_icon | image_url: width: 48 }}" alt="" loading="lazy">
                    {%- else -%}
                      {%- if section.settings.bullet_icon_type == 'checkmark' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      {%- endif -%}
                    {%- endif -%}
                  </span>
                  <span>{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <!-- Alert horizontal box -->
      {%- if section.settings.alert_text != blank -%}
        <div class="bb-problem-v2__alert bb-fade-in">
          {{ section.settings.alert_text }}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- endunless -%}



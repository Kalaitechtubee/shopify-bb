      "type": "color",
      "id": "item_text_color",
      "label": "List Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "item_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "List Font Size",
      "default": 16
    },
    {

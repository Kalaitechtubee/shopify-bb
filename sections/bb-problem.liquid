        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 24,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Desktop",
      "default": 72
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Mobile",
      "default": 42
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "default": "800",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" },
        { "value": "900", "label": "Black (Heavy)" }
      ]
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Heading Margin Bottom",
      "default": 48
    },
    {
      "type": "header",
      "content": "Panel Options"
    },
    {
      "type": "color",
      "id": "panel_bg_color",
      "label": "Panel Background Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "panel_border_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Panel Border Radius",
      "default": 16
    },
    {
      "type": "range",
      "id": "panel_padding_desktop",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Panel Padding — Desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "panel_padding_mobile",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Panel Padding — Mobile",

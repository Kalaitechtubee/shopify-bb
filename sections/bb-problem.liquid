    {
      "type": "color",
      "id": "alert_bg_color",
      "label": "Alert Background Color",
      "default": "#FAF0F0"
    },
    {
      "type": "color",
      "id": "alert_border_color",
      "label": "Alert Left Border Color",
      "default": "#622229"
    },
    {
      "type": "range",
      "id": "alert_border_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Alert Left Border Thickness",
      "default": 4
    },
    {
      "type": "color",
      "id": "alert_text_color",
      "label": "Alert Text Color",
      "default": "#1a1a1a"
    },
    {

      "id": "quote_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Quote Font Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "quote_margin_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Quote Margin Bottom",
      "default": 24
    },
    {
      "type": "header",
      "content": "Checklist Settings"

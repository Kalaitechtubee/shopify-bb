{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-stats-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    
    /* Map CSS custom variables for complete customization */
    --stats-bg: {{ section.settings.background_color }};
    --stats-num-color: {{ section.settings.number_color }};
    --stats-label-color: {{ section.settings.label_color }};
    
    --stats-border-width: {{ section.settings.border_width }}px;
    --stats-border-style: {{ section.settings.border_style }};
    --stats-border-color: {{ section.settings.border_color }};
    
    --stats-divider-width: {{ section.settings.divider_width }}px;
    --stats-divider-style: {{ section.settings.divider_style }};
    --stats-divider-color: {{ section.settings.divider_color }};
    
    --stats-num-size: {{ section.settings.number_size }}px;
    --stats-num-weight: {{ section.settings.number_weight }};
    --stats-label-size: {{ section.settings.label_size }}px;
    --stats-label-weight: {{ section.settings.label_weight }};
    
    --stats-padding-y: {{ section.settings.padding_top }}px;
  }
  @media (min-width: 768px) {
    #bb-stats-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-stats-{{ section.id }}"
  class="bb-section bb-stats {% if section.settings.style_preset == 'light' %}bb-stats--style-light{% endif %} {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-stats__inner">

      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="bb-stats__item bb-fade-in" {{ block.shopify_attributes }}>
            <p class="bb-stats__number">{{ block.settings.number }}</p>
            <p class="bb-stats__label">{{ block.settings.label }}</p>
          </div>
        {%- endif -%}
      {%- else -%}

        <!-- Default / demo stats when no blocks defined -->
        {%- if section.settings.stat_1_number != blank -%}
          <div class="bb-stats__item bb-fade-in">
            <p class="bb-stats__number">{{ section.settings.stat_1_number }}</p>
            <p class="bb-stats__label">{{ section.settings.stat_1_label }}</p>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_2_number != blank -%}
          <div class="bb-stats__item bb-fade-in">
            <p class="bb-stats__number">{{ section.settings.stat_2_number }}</p>
            <p class="bb-stats__label">{{ section.settings.stat_2_label }}</p>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_3_number != blank -%}
          <div class="bb-stats__item bb-fade-in">
            <p class="bb-stats__number">{{ section.settings.stat_3_number }}</p>
            <p class="bb-stats__label">{{ section.settings.stat_3_label }}</p>
          </div>
        {%- endif -%}

      {%- endfor -%}

    </div>
  </div>
</section>

{%- endunless -%}

{% schema %}
{
  "name": "BB Stats Strip",
  "tag": "section",
  "class": "bb-section-stats",
  "settings": [
    {
      "type": "header",
      "content": "Section Control"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable Section",
      "default": true
    },
    {
      "type": "select",
      "id": "style_preset",
      "label": "Style Preset",
      "default": "light",
      "options": [
        {
          "value": "classic",
          "label": "Classic (Dark Color Background)"
        },
        {
          "value": "light",
          "label": "Light (White Background, Custom Dividers)"
        }
      ]
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    },
    {
      "type": "header",
      "content": "Default Stats (used if no blocks are added)"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 Number",
      "default": "Korean"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "Patented tech"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 Number",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Avg. rating"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 Number",
      "default": "Week 2"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Results begin"
    },
    {
      "type": "header",
      "content": "Borders & Dividers"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Top & Bottom Border Width",
      "default": 1
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "default": "solid",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#efefef"
    },
    {
      "type": "range",
      "id": "divider_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Vertical Divider Width",
      "default": 1
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Divider Style",
      "default": "solid",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Color",
      "default": "#efefef"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Value (Number) Color",
      "default": "#622229"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#777777"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "number_size",
      "min": 16,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Number Font Size",
      "default": 36
    },
    {
      "type": "select",
      "id": "number_weight",
      "label": "Number Font Weight",
      "default": "800",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "600",
          "label": "Semi-Bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra Bold"
        },
        {
          "value": "900",
          "label": "Black"
        }
      ]
    },
    {

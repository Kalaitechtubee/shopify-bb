{%- unless section.settings.enable_section == false -%}
{%- assign _bb_meta = product.metafields.custom.faqs.value -%}
{%- if section.blocks.size == 0 and _bb_meta == blank -%}{%- assign _skip_section = true -%}{%- endif -%}
{%- unless _skip_section -%}

{%- style -%}
  #bb-faq-{{ section.id }} {
    background-color: #FFFFFF;
    padding-top: {{ section.settings.padding_top | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
    padding-left: {{ section.settings.padding_left | default: 0 }}px;
    padding-right: {{ section.settings.padding_right | default: 0 }}px;
    margin-top: {{ section.settings.margin_top | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;

    --faq-max-width: {{ section.settings.container_max_width }}px;
    --faq-badge-size: {{ section.settings.badge_font_size }}px;
    --faq-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    --faq-title-size: {{ section.settings.title_font_size }}px;
    --faq-title-margin: {{ section.settings.title_margin_bottom }}px;
    --faq-card-height: {{ section.settings.card_height }}px;
    --faq-card-gap: {{ section.settings.card_gap }}px;
    --faq-card-padding-x: {{ section.settings.card_padding_x }}px;
    --faq-card-radius: {{ section.settings.card_border_radius }}px;
    --faq-q-size: {{ section.settings.q_font_size }}px;
    --faq-a-size: {{ section.settings.a_font_size }}px;
  }
  
  #bb-faq-{{ section.id }} .bb-container {
    max-width: var(--faq-max-width);
    width: 100%;
    
    {%- if section.settings.alignment == 'left' -%}
      margin-left: 0;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'center' -%}
      margin-left: auto;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'right' -%}
      margin-left: auto;
      margin-right: 0;
    {%- endif -%}
    
    text-align: {{ section.settings.alignment }};
  }

  /* Badge styling */
  #bb-faq-{{ section.id }} .bb-faq-badge {
    display: inline-block;
    text-transform: uppercase;
    font-size: var(--faq-badge-size);
    font-weight: 700;
    letter-spacing: 2px;
    background-color: #F7E9E8;
    color: #7B2F3A;
    padding: 7px 18px;
    border-radius: 999px;
    margin-bottom: var(--faq-badge-margin);
    line-height: 1;
  }

  /* Title styling */
  #bb-faq-{{ section.id }} .bb-faq-title {
    font-size: var(--faq-title-size);
    font-weight: {{ section.settings.title_weight | default: '800' }};
    line-height: 1;
    letter-spacing: -2px;
    margin: 0 0 var(--faq-title-margin) 0;
    text-align: {{ section.settings.alignment }};
  }
  #bb-faq-{{ section.id }} .bb-faq-title-navy {
    color: #17123B;
  }
  #bb-faq-{{ section.id }} .bb-faq-title-maroon {
    color: #6B2430;
    display: block;
  }

  /* List Container */
  #bb-faq-{{ section.id }} .bb-faq-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--faq-card-gap);
  }

  /* Accordion Card Styling */
  #bb-faq-{{ section.id }} .bb-faq-card {
    width: 100%;
    background-color: #FFFFFF;
    border: 1px solid #F1E4E3;
    border-radius: var(--faq-card-radius);
    transition: 0.3s ease;
    overflow: hidden;
    box-sizing: border-box;
    text-align: left;
  }

  #bb-faq-{{ section.id }} .bb-faq-card__trigger {
    width: 100%;
    height: var(--faq-card-height);
    padding: 0 var(--faq-card-padding-x);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    box-sizing: border-box;
    gap: 20px;
  }

  #bb-faq-{{ section.id }} .bb-faq-card__question {
    color: #17123B;
    font-size: var(--faq-q-size);
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
    text-align: left;
  }

  #bb-faq-{{ section.id }} .bb-faq-card__plus {
    width: 28px;
    height: 28px;
    background-color: #F8ECEB;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background-color 0.2s ease;
  }

  #bb-faq-{{ section.id }} .bb-faq-card__trigger:hover .bb-faq-card__plus {
    background-color: #F3DCDA; /* slightly darker on hover */
  }

  #bb-faq-{{ section.id }} .bb-faq-card__plus-icon {
    color: #7B2F3A;
    font-size: 20px;
    font-weight: 500;
    line-height: 1;
    display: inline-block;
    transition: transform 0.3s ease;
    transform: translateY(-1px); /* Perfect vertical centering of plus icon */
  }

  #bb-faq-{{ section.id }} .bb-faq-card__content-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  #bb-faq-{{ section.id }} .bb-faq-card__content {
    overflow: hidden;
    padding: 0 var(--faq-card-padding-x);
    font-size: var(--faq-a-size);
    line-height: 1.8;
    color: #555555;
    box-sizing: border-box;
  }

  /* Expanded State overrides */
  #bb-faq-{{ section.id }} .bb-faq-card--open .bb-faq-card__content-wrapper {
    grid-template-rows: 1fr;
  }

  #bb-faq-{{ section.id }} .bb-faq-card--open .bb-faq-card__content {
    padding-bottom: var(--faq-card-padding-x);
  }

  #bb-faq-{{ section.id }} .bb-faq-card--open .bb-faq-card__plus-icon {
    transform: rotate(45deg);
  }

  /* Responsive Styling */
  @media (max-width: 1024px) {
    #bb-faq-{{ section.id }} {
      padding-left: {{ section.settings.padding_left_mobile | default: 0 }}px;
      padding-right: {{ section.settings.padding_right_mobile | default: 0 }}px;
      --faq-title-size: {{ section.settings.title_font_size_tablet }}px;
    }
  }

  @media (max-width: 767px) {
    #bb-faq-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: 0 }}px;
      padding-left: {{ section.settings.padding_left_mobile | default: 0 }}px;
      padding-right: {{ section.settings.padding_right_mobile | default: 0 }}px;
      margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
      --faq-title-size: {{ section.settings.title_font_size_mobile }}px;
      --faq-card-height: auto;
      --faq-q-size: {{ section.settings.q_font_size_mobile }}px;
    }
    #bb-faq-{{ section.id }} .bb-faq-card__trigger {
      padding: 18px;
    }
    #bb-faq-{{ section.id }} .bb-faq-card__content {
      padding: 0 18px;
    }
    #bb-faq-{{ section.id }} .bb-faq-card--open .bb-faq-card__content {
      padding-bottom: 18px;
    }
  }
{%- endstyle -%}

<section
  id="bb-faq-{{ section.id }}"
  class="bb-faq-section-wrapper {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    
    <!-- Subheading Badge -->
    {%- if section.settings.subheading != blank -%}
      <div class="bb-faq-badge">{{ section.settings.subheading }}</div>
    {%- endif -%}

    <!-- Main Heading -->
    {%- if section.settings.heading != blank -%}
      <h2 class="bb-faq-title">
        {%- assign h_lower = section.settings.heading | downcase -%}
        {%- if h_lower contains "questions" and h_lower contains "answered" -%}
          <span class="bb-faq-title-navy">Your questions,</span>
          <span class="bb-faq-title-maroon">answered</span>
        {%- else -%}
          {{ section.settings.heading }}
        {%- endif -%}
      </h2>
    {%- endif -%}

    <!-- Accordion List -->
    <div class="bb-faq-v2__list">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq_item' -%}
            {%- assign is_open = block.settings.open_by_default -%}
            {% render 'accordion',
              question: block.settings.question,
              answer: block.settings.answer,
              defaultOpen: is_open,
              index: forloop.index
            %}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{%- endunless -%}{%- comment -%}end _skip_section{%- endcomment -%}
{%- endunless -%}


{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-faq-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    
    /* CSS Variables mapping for complete customization */
    --faq-bg: {{ section.settings.background_color }};
    --faq-max-width: {{ section.settings.container_max_width }}px;
    
    --faq-badge-bg: {{ section.settings.badge_bg_color }};
    --faq-badge-text: {{ section.settings.badge_text_color }};
    --faq-badge-border: {{ section.settings.badge_border_color }};
    --faq-badge-radius: {{ section.settings.badge_border_radius }}px;
    --faq-badge-size: {{ section.settings.badge_font_size }}px;
    --faq-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --faq-heading-size: {{ section.settings.heading_size_desktop }}px;
    --faq-heading-weight: {{ section.settings.heading_weight }};
    --faq-heading-color: {{ section.settings.heading_color }};
    --faq-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --faq-gap: {{ section.settings.grid_gap }}px;
    
    --faq-card-bg: {{ section.settings.card_bg_color }};
    --faq-card-border-color: {{ section.settings.card_border_color }};
    --faq-card-border-width: {{ section.settings.card_border_width }}px;
    --faq-card-radius: {{ section.settings.card_border_radius }}px;
    --faq-card-padding: {{ section.settings.card_padding }}px;
    --faq-card-active-border: {{ section.settings.card_active_border }};
    
    --faq-icon-size: {{ section.settings.icon_size }}px;
    --faq-icon-bg: {{ section.settings.icon_bg_color }};
    --faq-icon-color: {{ section.settings.icon_symbol_color }};
    --faq-icon-border: {{ section.settings.icon_border_color }};
    
    --faq-q-size: {{ section.settings.question_size }}px;
    --faq-q-weight: {{ section.settings.question_weight }};
    --faq-q-color: {{ section.settings.question_color }};
    
    --faq-a-size: {{ section.settings.answer_size }}px;
    --faq-a-color: {{ section.settings.answer_color }};
  }
  @media (min-width: 768px) {
    #bb-faq-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-faq-{{ section.id }} .bb-faq-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-faq-{{ section.id }}"
  class="bb-section bb-faq-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-faq-v2__inner bb-text-center">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-faq-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-faq-v2__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <!-- Accordion List -->
      <div class="bb-faq-v2__list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq_item' -%}
              {%- assign is_open = block.settings.open_by_default -%}
              {%- assign item_id = 'bb-faq-item-' | append: block.id -%}
              <div class="bb-faq-v2__card bb-accordion-v2__item {% if is_open %}bb-accordion-v2__item--open bb-faq-v2__card--open{% endif %}" {{ block.shopify_attributes }}>
                <button
                  class="bb-faq-v2__trigger bb-accordion-v2__trigger"
                  aria-expanded="{{ is_open }}"
                  aria-controls="{{ item_id }}"
                  type="button"
                >
                  <span class="bb-faq-v2__trigger-text">{{ block.settings.question }}</span>
                  <span class="bb-faq-v2__icon-wrap" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <line x1="12" y1="5" x2="12" y2="19"/>
                      <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                  </span>
                </button>
                <div class="bb-faq-v2__content" id="{{ item_id }}" role="region">
                  {{ block.settings.answer }}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign faq_meta = product.metafields.custom.faq_items.value -%}
          {%- if faq_meta != blank -%}
            {%- for item in faq_meta -%}
              {%- assign item_id = 'bb-faq-meta-' | append: forloop.index -%}
              <div class="bb-faq-v2__card bb-accordion-v2__item" {{ block.shopify_attributes }}>
                <button
                  class="bb-faq-v2__trigger bb-accordion-v2__trigger"
                  aria-expanded="false"
                  aria-controls="{{ item_id }}"
                  type="button"
                >
                  <span class="bb-faq-v2__trigger-text">{{ item.question }}</span>
                  <span class="bb-faq-v2__icon-wrap" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <line x1="12" y1="5" x2="12" y2="19"/>
                      <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                  </span>
                </button>
                <div class="bb-faq-v2__content" id="{{ item_id }}" role="region">
                  <p>{{ item.answer }}</p>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- endunless -%}

{% schema %}
{

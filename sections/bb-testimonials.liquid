{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}
{%- assign test_meta_check = product.metafields.custom.testimonials.value -%}
{%- if section.blocks.size == 0 and test_meta_check == blank -%}{%- assign _skip_section = true -%}{%- endif -%}
{%- unless _skip_section -%}

{%- style -%}
  #bb-testimonials-{{ section.id }} {
    background-color: var(--test-bg, #ffffff);
    padding-top: {{ section.settings.padding_top_mobile | default: 48 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 48 }}px;

    --test-bg: {{ section.settings.background_color }};
    --test-max-width: {{ section.settings.container_max_width }}px;
    --test-card-bg: {{ section.settings.card_bg_color }};
    --test-card-border-color: {{ section.settings.card_border_color }};
    --test-card-border-width: {{ section.settings.card_border_width }}px;
    --test-card-radius: {{ section.settings.card_border_radius }}px;
    --test-card-padding: {{ section.settings.card_padding }}px;
    --test-card-width: {{ section.settings.card_width }}px;
    --test-hover-border: {{ section.settings.card_hover_border_color | default: '#622229' }};
    --test-star-color: {{ section.settings.star_color }};
    --test-star-size: {{ section.settings.star_size }}px;
    --test-heading-size: {{ section.settings.heading_size_desktop }}px;
    --test-heading-weight: {{ section.settings.heading_weight }};
    --test-heading-color: {{ section.settings.heading_color }};
    --test-sub-size: {{ section.settings.subheading_size }}px;
    --test-sub-color: {{ section.settings.subheading_color }};
    --test-text-size: {{ section.settings.text_size }}px;
    --test-text-color: {{ section.settings.text_color }};
    --test-name-size: {{ section.settings.name_size }}px;
    --test-name-color: {{ section.settings.name_color }};
    --test-scroll-speed: {{ section.settings.scroll_speed }}s;
    --test-gap: {{ section.settings.card_gap }}px;
  }

  @media (min-width: 768px) {
    #bb-testimonials-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | default: 80 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
      padding-left: {{ section.settings.padding_left | default: 0 }}px;
      padding-right: {{ section.settings.padding_right | default: 0 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
    }
    #bb-testimonials-{{ section.id }} .bb-testimonials-v2__heading {
      font-size: var(--test-heading-size, 48px);
    }
  }
  @media (max-width: 767px) {
    #bb-testimonials-{{ section.id }} .bb-testimonials-v2__heading {
      font-size: {{ section.settings.heading_size_mobile | default: 28 }}px;
    }
  }

  /* Inner alignment (heading/subtitle above marquee) */
  #bb-testimonials-{{ section.id }} .bb-container {
    max-width: var(--test-max-width);
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__header {
    display: flex;
    flex-direction: column;
    align-items: {%- if section.settings.heading_alignment == 'left' -%}flex-start{%- elsif section.settings.heading_alignment == 'right' -%}flex-end{%- else -%}center{%- endif -%};
    text-align: {{ section.settings.heading_alignment | default: 'center' }};
    margin-bottom: {{ section.settings.heading_margin_bottom | default: 48 }}px;
  }

  /* Heading */
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__heading {
    font-size: var(--test-heading-size, 48px);
    font-weight: var(--test-heading-weight, 800);
    color: var(--test-heading-color, #17123B);
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin: 0 0 16px 0;
    text-align: inherit;
    width: 100%;
  }

  /* Subtitle */
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__subheading {
    font-size: var(--test-sub-size, 16px);
    color: var(--test-sub-color, #6B2430);
    margin: 0;
    width: 100%;
    max-width: 640px;
    text-align: {{ section.settings.subtitle_alignment | default: 'center' }};
    {%- if section.settings.subtitle_alignment == 'center' or section.settings.subtitle_alignment == blank -%}
      align-self: center;
    {%- elsif section.settings.subtitle_alignment == 'right' -%}
      align-self: flex-end;
    {%- else -%}
      align-self: flex-start;
    {%- endif -%}
  }

  /* ── Marquee Scroller ── */
  #bb-testimonials-{{ section.id }} .bb-marquee-wrapper {
    width: 100%;
    position: relative;
  }
  #bb-testimonials-{{ section.id }} .bb-marquee-clip {
    overflow: hidden;     /* horizontal clip for the marquee */
    width: 100%;
    position: relative;
    padding: 24px 0;      /* lets hover shadow + lift be visible */
    margin: -12px 0;      /* counteract vertical padding for layout consistency */
  }
  #bb-testimonials-{{ section.id }} .bb-marquee-clip::before,
  #bb-testimonials-{{ section.id }} .bb-marquee-clip::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  #bb-testimonials-{{ section.id }} .bb-marquee-clip::before {
    left: 0;
    background: linear-gradient(to right, var(--test-bg, #ffffff), transparent);
  }
  #bb-testimonials-{{ section.id }} .bb-marquee-clip::after {
    right: 0;
    background: linear-gradient(to left, var(--test-bg, #ffffff), transparent);
  }

  #bb-testimonials-{{ section.id }} .bb-marquee-track {
    display: flex;
    gap: var(--test-gap, 24px);
    width: max-content;
    animation: bb-marquee-scroll var(--test-scroll-speed, 30s) linear infinite;
  }
  #bb-testimonials-{{ section.id }} .bb-marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes bb-marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Cards */
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__card {
    background: var(--test-card-bg, #ffffff);
    border: var(--test-card-border-width, 1px) solid var(--test-card-border-color, #eeeeee);
    border-radius: var(--test-card-radius, 16px);
    padding: var(--test-card-padding, 28px);
    width: var(--test-card-width, 320px);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    cursor: pointer;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__card:hover {
    border-color: var(--test-hover-border, {{ section.settings.card_hover_border_color | default: '#622229' }});
    box-shadow: 0 8px 32px rgba(98, 34, 41, 0.12);
    transform: translateY(-4px);
  }

  /* Stars */
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__stars {
    display: flex;
    gap: 3px;
    margin-bottom: 12px;
  }
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__stars svg {
    width: var(--test-star-size, 18px);
    height: var(--test-star-size, 18px);
    fill: var(--test-star-color, #622229);
    flex-shrink: 0;
  }

  /* Review text */
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__text {
    font-size: var(--test-text-size, 15px);
    color: var(--test-text-color, #333333);
    line-height: 1.65;
    margin: 0;
    flex-grow: 1;
  }

  /* Customer name */
  #bb-testimonials-{{ section.id }} .bb-testimonials-v2__name {
    font-size: var(--test-name-size, 14px);
    font-weight: 700;
    color: var(--test-name-color, #17123B);
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid var(--test-card-border-color, #eeeeee);
  }
{%- endstyle -%}

<section
  id="bb-testimonials-{{ section.id }}"
  class="bb-section bb-testimonials-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>

  <!-- Heading & Subtitle -->
  <div class="bb-container">
    <div class="bb-testimonials-v2__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-testimonials-v2__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="bb-testimonials-v2__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  </div>

  <!-- Marquee Scrolling Cards -->
  <div class="bb-marquee-wrapper">
    <div class="bb-marquee-clip">
      <div class="bb-marquee-track">
      {%- comment -%}First pass of cards{%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            <div class="bb-testimonials-v2__card" {{ block.shopify_attributes }}>
              <div>
                <div class="bb-testimonials-v2__stars">
                  {%- for i in (1..block.settings.rating) -%}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {%- endfor -%}
                </div>
                <p class="bb-testimonials-v2__text">"{{ block.settings.text }}"</p>
              </div>
              <p class="bb-testimonials-v2__name">{{ block.settings.name }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
        {%- comment -%}Duplicate for infinite loop{%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            <div class="bb-testimonials-v2__card" aria-hidden="true">
              <div>
                <div class="bb-testimonials-v2__stars">
                  {%- for i in (1..block.settings.rating) -%}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {%- endfor -%}
                </div>
                <p class="bb-testimonials-v2__text">"{{ block.settings.text }}"</p>
              </div>
              <p class="bb-testimonials-v2__name">{{ block.settings.name }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign test_meta = product.metafields.custom.testimonials.value -%}
        {%- if test_meta != blank -%}
          {%- for item in test_meta -%}
            <div class="bb-testimonials-v2__card">
              <div>
                <div class="bb-testimonials-v2__stars">
                  {%- for i in (1..item.rating) -%}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {%- endfor -%}
                </div>
                <p class="bb-testimonials-v2__text">"{{ item.text }}"</p>
              </div>
              <p class="bb-testimonials-v2__name">{{ item.name }}</p>
            </div>
          {%- endfor -%}
          {%- for item in test_meta -%}
            <div class="bb-testimonials-v2__card" aria-hidden="true">
              <div>
                <div class="bb-testimonials-v2__stars">
                  {%- for i in (1..item.rating) -%}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {%- endfor -%}
                </div>
                <p class="bb-testimonials-v2__text">"{{ item.text }}"</p>
              </div>
              <p class="bb-testimonials-v2__name">{{ item.name }}</p>
            </div>
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
      </div><!-- /.bb-marquee-track -->
    </div><!-- /.bb-marquee-clip -->
  </div><!-- /.bb-marquee-wrapper -->

</section>

{%- endunless -%}{%- comment -%}end _skip_section{%- endcomment -%}
{%- endunless -%}{%- comment -%}end enable_section{%- endcomment -%}

{% schema %}
{
  "name": "BB Testimonials",
  "tag": "section",
  "class": "bb-section-testimonials",
  "settings": [
    {
      "type": "header",
      "content": "Section Control"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable Section",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 400,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Heading Container Max Width",
      "default": 1280
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Listen to what our customers Say"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#17123B"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Desktop",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Mobile",
      "default": 28
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "default": "800",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "600",
          "label": "Semi-Bold"

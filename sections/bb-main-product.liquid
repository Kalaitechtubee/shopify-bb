{{ 'bb-theme.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bb-theme.js' | asset_url }}" defer></script>

{%- liquid
  assign section_enabled = section.settings.enable_section
  assign bg_color        = section.settings.background_color
  assign heading_color   = section.settings.heading_color
  assign text_color      = section.settings.text_color
  assign pt_desktop      = section.settings.padding_top
  assign pb_desktop      = section.settings.padding_bottom
  assign pt_mobile       = section.settings.padding_top_mobile
  assign pb_mobile       = section.settings.padding_bottom_mobile
  assign custom_class    = section.settings.custom_class
-%}

{%- unless section_enabled == false -%}

{%- style -%}
  #bb-product-hero-{{ section.id }} {
    background-color: {{ bg_color }};
    padding-top: {{ pt_mobile }}px;
    padding-bottom: {{ pb_mobile }}px;

    /* Price and rating variables */
    --price-size: {{ section.settings.price_size }}px;
    --price-color: {{ section.settings.price_color }};
    --compare-price-size: {{ section.settings.compare_price_size }}px;
    --compare-price-color: {{ section.settings.compare_price_color }};
    --rating-star-color: {{ section.settings.rating_star_color }};
    --rating-star-size: {{ section.settings.rating_star_size }}px;

    /* Description variables */
    --desc-size: {{ section.settings.desc_size }}px;
    --desc-line-height: {{ section.settings.desc_line_height }};
    --desc-color: {{ section.settings.desc_color }};
    --desc-margin-bottom: {{ section.settings.desc_margin_bottom }}px;

    /* Highlight pills variables */
    --pill-bg: {{ section.settings.pills_bg_color }};
    --pill-text: {{ section.settings.pills_text_color }};
    --pill-icon-color: #A3FE01;
    --pill-size: {{ section.settings.pills_font_size }}px;
    --pill-padding: {{ section.settings.pills_padding_y }}px {{ section.settings.pills_padding_x }}px;
    --pill-radius: {{ section.settings.pills_border_radius }}px;
    --pill-gap: {{ section.settings.pills_gap }}px;
    --pills-gap-x: {{ section.settings.pills_gap_x }}px;
    --pills-gap-y: {{ section.settings.pills_gap_y }}px;
    --pills-margin-bottom: {{ section.settings.pills_margin_bottom }}px;
    --pill-icon-size: {{ section.settings.pills_icon_size }}px;

    /* CTA button variables */
    --btn-bg: {{ section.settings.btn_bg_color }};
    --btn-text: {{ section.settings.btn_text_color }};
    --btn-hover-bg: {{ section.settings.btn_hover_bg_color }};
    --btn-height: {{ section.settings.btn_height }}px;
    --btn-font-size: {{ section.settings.btn_font_size }}px;
    --btn-border-radius: {{ section.settings.btn_border_radius }}px;
    --btn-padding-y: {{ section.settings.btn_padding_y }}px;
    --btn-padding-x: {{ section.settings.btn_padding_x }}px;
    --btn-offset: {{ section.settings.btn_offset | default: 6 }}px;

    /* Quantity variables */
    --qty-bg: {{ section.settings.qty_bg_color }};
    --qty-border-color: {{ section.settings.qty_border_color }};
    --qty-text-color: {{ section.settings.qty_text_color }};
    --qty-width: {{ section.settings.qty_width }}px;
    --qty-height: {{ section.settings.qty_height }}px;
    --qty-border-radius: {{ section.settings.qty_border_radius }}px;

    /* Accordion variables */
    --acc-border-color: {{ section.settings.acc_border_color }};
    --acc-divider-color: {{ section.settings.acc_border_color }};
    --acc-bg: {{ section.settings.acc_bg_color }};
    --acc-trigger-color: {{ section.settings.acc_trigger_color }};
    --acc-trigger-size: {{ section.settings.acc_trigger_size }}px;
    --acc-trigger-weight: {{ section.settings.acc_trigger_weight }};
    --acc-content-color: {{ section.settings.acc_content_color }};
    --acc-content-size: {{ section.settings.acc_content_size }}px;
    --acc-icon-bg: {{ section.settings.acc_icon_bg }};
    --acc-icon-color: {{ section.settings.acc_icon_color }};
    --acc-icon-size: {{ section.settings.acc_icon_size }}px;
    --acc-border-radius: {{ section.settings.acc_border_radius }}px;
    --acc-margin-bottom: {{ section.settings.acc_margin_bottom }}px;
    --acc-trigger-padding: {{ section.settings.acc_trigger_padding_y }}px {{ section.settings.acc_trigger_padding_x }}px;
    --acc-content-padding: 0 {{ section.settings.acc_trigger_padding_x }}px {{ section.settings.acc_trigger_padding_y }}px {{ section.settings.acc_trigger_padding_x }}px;

    /* Gallery variables */
    --gal-arrow-bg: {{ section.settings.gal_arrow_bg }};
    --gal-arrow-hover-bg: {{ section.settings.gal_arrow_hover_bg }};
    --gal-arrow-color: {{ section.settings.gal_arrow_color }};
    --gal-arrow-size: {{ section.settings.gal_arrow_size }}px;
  }
  #bb-product-hero-{{ section.id }} .bb-product-info__title {
    color: {{ heading_color }};
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: {{ section.settings.heading_weight }};
  }
  
  /* Apply price styling overrides */
  #bb-product-hero-{{ section.id }} .bb-product-info__price {
    font-size: var(--price-size);
    color: var(--price-color);
  }
  #bb-product-hero-{{ section.id }} .bb-product-info__compare-price {
    font-size: var(--compare-price-size);
    color: var(--compare-price-color);
  }
  #bb-product-hero-{{ section.id }} .bb-stars__star {
    fill: var(--rating-star-color);
    color: var(--rating-star-color);
    width: var(--rating-star-size);
    height: var(--rating-star-size);
  }

  /* Description style overrides */
  #bb-product-hero-{{ section.id }} .bb-product-description-custom {
    font-size: var(--desc-size);
    line-height: var(--desc-line-height);
    color: var(--desc-color);
    margin-bottom: var(--desc-margin-bottom);
  }

  /* Quantity buttons style overrides */
  #bb-product-hero-{{ section.id }} .bb-quantity {
    background: var(--qty-bg);
    border: 1.5px solid var(--qty-border-color);
    color: var(--qty-text-color);
    width: var(--qty-width);
    height: var(--qty-height);
    border-radius: var(--qty-border-radius);
  }
  #bb-product-hero-{{ section.id }} .bb-quantity__btn,
  #bb-product-hero-{{ section.id }} .bb-quantity__input {
    color: var(--qty-text-color);
  }

  /* CTA buttons overrides */
  .bb-btn-neobrutalist-wrapper {
    position: relative;
    width: 100%;
    {%- if section.settings.enable_neobrutalist_btn -%}
      background-color: var(--btn-hover-bg, #622229);
    {%- else -%}
      background-color: transparent;
    {%- endif -%}
    border-radius: var(--btn-border-radius);
    display: block;
  }
  #bb-product-hero-{{ section.id }} .bb-btn--primary-custom {
    background-color: var(--btn-bg);
    color: var(--btn-text);
    border: none;
    border-radius: var(--btn-border-radius);
    height: var(--btn-height);
    font-size: var(--btn-font-size);
    padding: var(--btn-padding-y) var(--btn-padding-x);
    transform: translate(0, 0);
    position: relative;
    z-index: 2;
    cursor: pointer;
    {%- if section.settings.enable_neobrutalist_btn -%}
      transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    {%- else -%}
      transition: background-color 0.25s ease, color 0.25s ease;
    {%- endif -%}
  }
  #bb-product-hero-{{ section.id }} .bb-btn--primary-custom:hover {
    {%- if section.settings.enable_neobrutalist_btn -%}
      transform: translate(calc(-1 * var(--btn-offset)), calc(-1 * var(--btn-offset)));
      background-color: var(--btn-bg);
      color: var(--btn-text);
    {%- else -%}
      background-color: var(--btn-hover-bg);
      color: var(--btn-text);
    {%- endif -%}
  }
  #bb-product-hero-{{ section.id }} .bb-btn--primary-custom[disabled]:hover {
    transform: none;
  }

  @media (min-width: 768px) {
    #bb-product-hero-{{ section.id }} {
      padding-top: {{ pt_desktop }}px;
      padding-bottom: {{ pb_desktop }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-product-hero-{{ section.id }} .bb-product-info__title {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-product-hero-{{ section.id }}"
  class="bb-section bb-product-hero {{ custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-product-hero__inner">

      <!-- ===== GALLERY ===== -->
      <div class="bb-product-gallery">
        {%- assign featured_image = product.featured_image -%}
        <div class="bb-product-gallery__main-wrap">
          <div class="bb-product-gallery__main" style="margin-bottom:0;">
            {%- if featured_image -%}
              <img
                src="{{ featured_image | image_url: width: 800 }}"
                srcset="
                  {{ featured_image | image_url: width: 400 }} 400w,
                  {{ featured_image | image_url: width: 800 }} 800w,
                  {{ featured_image | image_url: width: 1200 }} 1200w
                "
                sizes="(max-width: 900px) 100vw, 50vw"
                alt="{{ featured_image.alt | escape | default: product.title | escape }}"
                width="{{ featured_image.width }}"
                height="{{ featured_image.height }}"
                loading="eager"
                fetchpriority="high"
                id="bb-main-image-{{ section.id }}"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          {%- if section.settings.show_gal_arrows and product.images.size > 1 -%}
            <button type="button" class="bb-product-gallery__arrow bb-product-gallery__arrow--prev" aria-label="Previous image">
              <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
            </button>
            <button type="button" class="bb-product-gallery__arrow bb-product-gallery__arrow--next" aria-label="Next image">
              <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
            </button>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="bb-product-gallery__thumbs">
            {%- for image in product.images limit: 6 -%}
              <button
                class="bb-product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                data-src="{{ image | image_url: width: 800 }}"
                data-srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 800 }} 800w"
                aria-label="{{ image.alt | escape | default: product.title | escape }}"
                type="button"
              >
                <img
                  src="{{ image | image_url: width: 144 }}"
                  alt="{{ image.alt | escape }}"
                  width="72"
                  height="72"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <!-- /GALLERY -->

      <!-- ===== PRODUCT INFO ===== -->
      <div class="bb-product-info">
        {%- if section.settings.show_badges and section.settings.badge_text != blank -%}
          <div class="bb-product-info__badges">
            {%- assign badge_array = section.settings.badge_text | split: ',' -%}
            {%- for badge_item in badge_array -%}
              {%- if badge_item != blank -%}
                <span class="bb-badge" style="
                  background-color: {{ section.settings.badge_bg_color | default: 'transparent' }};
                  color: {{ section.settings.badge_text_color | default: '#622229' }};
                  border: 1.5px solid {{ section.settings.badge_text_color | default: '#622229' }};
                  border-radius: {{ section.settings.badge_border_radius | default: 50 }}px;
                ">{{ badge_item | strip }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Title -->
        <h1 class="bb-product-info__title">{{ product.title }}</h1>

        <!-- Rating -->
        {%- if section.settings.show_rating -%}
          <div class="bb-product-info__rating-row">
            {%- assign review_rating  = section.settings.review_rating  | default: 4.8 -%}
            {%- assign review_count   = section.settings.review_count   | default: 248 -%}
            {% render 'rating-stars', rating: review_rating, max: 5, show_count: false %}
            <span class="bb-product-info__review-count" style="text-decoration:none;cursor:default;color:var(--bb-text);font-weight:600;margin-left:4px;">
              {{ review_rating }} stars &bull; ({{ review_count }} reviews)
            </span>
          </div>
        {%- endif -%}

        <!-- Short Description -->
        {%- if section.settings.show_short_description -%}
          {%- if section.settings.short_description != blank -%}
            <div class="bb-product-description-custom">{{ section.settings.short_description }}</div>
          {%- elsif product.description != blank -%}
            <div class="bb-product-description-custom">{{ product.description }}</div>
          {%- endif -%}
        {%- endif -%}

        <!-- Price -->
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        <div class="bb-product-info__price-row" style="margin-bottom: 16px;">
          <span class="bb-product-info__price">
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="bb-product-info__compare-price">
              {{ current_variant.compare_at_price | money }}
            </span>
            {%- assign saving = current_variant.compare_at_price | minus: current_variant.price -%}
            {%- assign saving_pct = saving | times: 100 | divided_by: current_variant.compare_at_price -%}
            <span class="bb-product-info__save">Save {{ saving_pct }}%</span>
          {%- endif -%}
        </div>

        <!-- Highlight Badges (Pill style) -->
        {%- if section.settings.highlight_badge_1 != blank or section.settings.highlight_badge_2 != blank or section.settings.highlight_badge_3 != blank -%}
          <div class="bb-product-info__highlights-v2">
            {%- if section.settings.highlight_badge_1 != blank -%}
              <div class="bb-highlight-pill-v2">
                <span class="bb-highlight-pill-v2__icon">
                  {%- if section.settings.pill_icon_1 != blank -%}
                    <img src="{{ section.settings.pill_icon_1 | image_url: width: 36 }}" alt="" width="14" height="14" loading="lazy">
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5">
                      <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor"></circle>
                      <path d="M8 12l3 3 5-6" stroke="currentColor"></path>
                    </svg>
                  {%- endif -%}
                </span>
                <span class="bb-highlight-pill-v2__text">{{ section.settings.highlight_badge_1 }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.highlight_badge_2 != blank -%}
              <div class="bb-highlight-pill-v2">
                <span class="bb-highlight-pill-v2__icon">
                  {%- if section.settings.pill_icon_2 != blank -%}
                    <img src="{{ section.settings.pill_icon_2 | image_url: width: 36 }}" alt="" width="14" height="14" loading="lazy">
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5">
                      <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor"></circle>
                      <path d="M8 12l3 3 5-6" stroke="currentColor"></path>
                    </svg>
                  {%- endif -%}
                </span>
                <span class="bb-highlight-pill-v2__text">{{ section.settings.highlight_badge_2 }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.highlight_badge_3 != blank -%}
              <div class="bb-highlight-pill-v2">
                <span class="bb-highlight-pill-v2__icon">
                  {%- if section.settings.pill_icon_3 != blank -%}
                    <img src="{{ section.settings.pill_icon_3 | image_url: width: 36 }}" alt="" width="14" height="14" loading="lazy">
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5">
                      <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor"></circle>
                      <path d="M8 12l3 3 5-6" stroke="currentColor"></path>
                    </svg>
                  {%- endif -%}
                </span>
                <span class="bb-highlight-pill-v2__text">{{ section.settings.highlight_badge_3 }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        <!-- Form: Variant Picker + Quantity + Add to Cart -->
        {%- assign bb_form_id = 'bb-product-form-' | append: section.id -%}
        <product-form>
          {%- form 'product', product, id: bb_form_id, novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">

            {%- unless product.has_only_default_variant -%}
              {%- for option in product.options_with_values -%}
                <div class="bb-mb-20">
                  <span class="bb-variant-label">{{ option.name }}</span>
                  <div class="bb-variant-options">
                    {%- for value in option.values -%}
                      {%- assign is_selected = false -%}
                      {%- if current_variant.options contains value -%}
                        {%- assign is_selected = true -%}
                      {%- endif -%}
                      <button
                        type="button"
                        class="bb-variant-option{% if is_selected %} is-selected{% endif %}"
                        data-option-index="{{ forloop.parentloop.index0 }}"
                        data-value="{{ value | escape }}"
                        aria-label="{{ option.name }}: {{ value | escape }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endunless -%}

            <!-- Quantity -->
            <div class="bb-quantity-row">
              <div class="bb-quantity">
                <button type="button" class="bb-quantity__btn bb-quantity__btn--plus" aria-label="Increase quantity">+</button>
                <input
                  class="bb-quantity__input"
                  type="number"
                  name="quantity"
                  id="bb-qty-{{ section.id }}"
                  value="1"
                  min="1"
                  aria-label="Quantity"
                >
                <button type="button" class="bb-quantity__btn bb-quantity__btn--minus" aria-label="Decrease quantity">−</button>
              </div>
            </div>

            <!-- Add to Cart -->
            <div class="bb-product-cta">
              <div class="bb-btn-neobrutalist-wrapper">
                <button
                  type="submit"
                  name="add"
                  class="bb-btn bb-btn--primary-custom bb-btn--full"
                  {% if current_variant.available == false %}disabled{% endif %}
                  style="display:flex;align-items:center;justify-content:center;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;"
                >
                  {%- if current_variant.available -%}
                    {{ section.settings.add_to_cart_text | default: 'Add to Cart' }}
                  {%- else -%}
                    Sold Out
                  {%- endif -%}
                </button>
              </div>
            </div>

            {%- if section.settings.show_secondary_cta and section.settings.secondary_cta_text != blank -%}
              <div class="bb-product-cta-secondary" style="margin-top: 16px;">
                <a
                  href="{{ section.settings.secondary_cta_url | default: '#' }}"
                  class="bb-btn bb-btn--outline bb-btn--full"
                  style="display:flex;align-items:center;justify-content:center;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;height:var(--btn-height);border-radius:var(--btn-border-radius);font-size:var(--btn-font-size);"
                >
                  {{ section.settings.secondary_cta_text }}
                </a>
              </div>
            {%- endif -%}

          {%- endform -%}
        </product-form>

        <!-- Trust Badges -->
        {%- if section.settings.show_trust_badges -%}
          {%- if section.settings.trust_badge_1 != blank or section.settings.trust_badge_2 != blank or section.settings.trust_badge_3 != blank or section.settings.trust_badge_4 != blank -%}
            <div class="bb-product-trust-badges" style="margin: 24px 0 32px; padding: 16px 0; border-top: 1px solid #E7E3E3; border-bottom: 1px solid #E7E3E3;">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px;">
                {%- if section.settings.trust_badge_1 != blank -%}
                  <div style="display: flex; align-items: center; gap: 8px; font-family: var(--bb-font-body); font-size: 13px; font-weight: 600; color: #1a1a1a;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#622229" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="width: 16px; height: 16px; flex-shrink:0;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>{{ section.settings.trust_badge_1 }}</span>
                  </div>
                {%- endif -%}
                {%- if section.settings.trust_badge_2 != blank -%}
                  <div style="display: flex; align-items: center; gap: 8px; font-family: var(--bb-font-body); font-size: 13px; font-weight: 600; color: #1a1a1a;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#622229" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="width: 16px; height: 16px; flex-shrink:0;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>{{ section.settings.trust_badge_2 }}</span>
                  </div>
                {%- endif -%}
                {%- if section.settings.trust_badge_3 != blank -%}
                  <div style="display: flex; align-items: center; gap: 8px; font-family: var(--bb-font-body); font-size: 13px; font-weight: 600; color: #1a1a1a;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#622229" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="width: 16px; height: 16px; flex-shrink:0;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>{{ section.settings.trust_badge_3 }}</span>
                  </div>
                {%- endif -%}
                {%- if section.settings.trust_badge_4 != blank -%}
                  <div style="display: flex; align-items: center; gap: 8px; font-family: var(--bb-font-body); font-size: 13px; font-weight: 600; color: #1a1a1a;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#622229" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="width: 16px; height: 16px; flex-shrink:0;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>{{ section.settings.trust_badge_4 }}</span>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}

        <!-- Accordions -->
        {%- assign accordion_blocks = section.blocks | where: "type", "accordion_item" -%}
        {%- if accordion_blocks.size > 0 -%}
          <div class="bb-accordion-v2">
            {%- for block in accordion_blocks -%}
              <div class="bb-accordion-v2__item" {{ block.shopify_attributes }}>
                <button type="button" class="bb-accordion-v2__trigger" aria-expanded="false">
                  <span style="display:flex;align-items:center;gap:12px;">
                    {%- if block.settings.icon_image != blank -%}
                      <img src="{{ block.settings.icon_image | image_url: width: 48 }}" alt="" width="20" height="20" loading="lazy">
                    {%- endif -%}
                    {{ block.settings.title }}
                  </span>
                  <span class="bb-accordion-v2__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </span>
                </button>
                <div class="bb-accordion-v2__content bb-rte">
                  {{ block.settings.content }}
                  {%- liquid
                    assign display_video = false
                    assign is_hosted = false
                    
                    if block.settings.video_type == 'hosted'
                      if block.settings.hosted_video != blank
                        assign display_video = true
                        assign is_hosted = true
                      endif
                    elsif block.settings.video_type == 'youtube'
                      if block.settings.video_url != blank
                        assign display_video = true
                      endif
                    elsif block.settings.video_type == 'auto' or block.settings.video_type == blank
                      if block.settings.hosted_video != blank
                        assign display_video = true
                        assign is_hosted = true
                      elsif block.settings.video_url != blank
                        assign display_video = true
                      endif
                    endif
                  -%}
                  
                  {%- if display_video -%}
                    <div class="bb-accordion-v2__video-wrapper">
                      {%- if is_hosted -%}
                        {{ block.settings.hosted_video | video_tag: autoplay: false, loop: true, muted: true, playsinline: true, controls: true, class: "bb-accordion-v2__video" }}
                      {%- else -%}
                        {%- if block.settings.video_url.type == 'youtube' -%}
                          <iframe
                            src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=0&mute=1&loop=1&playlist={{ block.settings.video_url.id }}&playsinline=1"
                            class="bb-accordion-v2__iframe"
                            allow="autoplay; encrypted-media"
                            allowfullscreen
                            title="{{ block.settings.title | escape }}"
                          ></iframe>
                        {%- elsif block.settings.video_url.type == 'vimeo' -%}
                          <iframe
                            src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=0&muted=1&loop=1&playsinline=1"
                            class="bb-accordion-v2__iframe"
                            allow="autoplay; encrypted-media"
                            allowfullscreen
                            title="{{ block.settings.title | escape }}"
                          ></iframe>
                        {%- endif -%}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
      <!-- /PRODUCT INFO -->

    </div>
  </div>
</section>

{%- endunless -%}


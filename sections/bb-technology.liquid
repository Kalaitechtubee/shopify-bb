{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-technology-{{ section.id }} {
    background-color: {{ section.settings.section_background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    
    /* Map CSS custom variables for complete customizability */
    --tech-max-width: {{ section.settings.container_max_width }}px;
    --tech-badge-bg: {{ section.settings.badge_bg_color }};
    --tech-badge-text: {{ section.settings.badge_text_color }};
    --tech-badge-border: {{ section.settings.badge_border_color }};
    --tech-badge-radius: {{ section.settings.badge_border_radius }}px;
    --tech-badge-size: {{ section.settings.badge_font_size }}px;
    --tech-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --tech-heading-size: {{ section.settings.heading_size_desktop }}px;
    --tech-heading-weight: {{ section.settings.heading_weight }};
    --tech-heading-color: {{ section.settings.heading_color }};
    --tech-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --tech-panel-bg: {{ section.settings.panel_bg_color }};
    --tech-panel-radius: {{ section.settings.panel_border_radius }}px;
    --tech-panel-padding-desktop: {{ section.settings.panel_padding_desktop }}px;
    
    --tech-panel-title-size: {{ section.settings.panel_title_font_size }}px;
    --tech-panel-title-color: {{ section.settings.panel_title_color }};
    --tech-panel-title-margin: {{ section.settings.panel_title_margin_bottom }}px;
    
    --tech-panel-sub-size: {{ section.settings.panel_sub_font_size }}px;
    --tech-panel-sub-color: {{ section.settings.panel_sub_color }};
    --tech-panel-sub-margin: {{ section.settings.panel_sub_margin_bottom }}px;
    
    --tech-list-gap: {{ section.settings.list_gap }}px;
    --tech-item-size: {{ section.settings.item_font_size }}px;
    --tech-item-color: {{ section.settings.item_text_color }};
    
    --tech-icon-size: {{ section.settings.icon_size }}px;
    --tech-icon-bg: {{ section.settings.icon_bg_color }};
    --tech-icon-color: {{ section.settings.icon_symbol_color }};
    
    --tech-panel-list-margin: {{ section.settings.list_margin_bottom }}px;
    --tech-footer-size: {{ section.settings.footer_font_size }}px;
    --tech-footer-color: {{ section.settings.footer_text_color }};
    --tech-footer-highlight-color: {{ section.settings.footer_highlight_color }};
  }
  @media (min-width: 768px) {
    #bb-technology-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-technology-{{ section.id }} .bb-tech-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
    #bb-technology-{{ section.id }} .bb-tech-v2__panel {
      padding: {{ section.settings.panel_padding_mobile }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-technology-{{ section.id }}"
  class="bb-section bb-technology-section-wrapper {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-tech-v2">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-tech-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading — navy line 1, maroon line 2 -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-tech-v2__heading">
          Micro-Needling<span class="bb-heading-maroon">Serum Technology</span>
        </h2>
      {%- endif -%}

      <!-- Dark Panel Box -->
      <div class="bb-tech-v2__panel bb-fade-in">
        
        <!-- Panel Title -->
        {%- if section.settings.panel_title != blank -%}
          <h3 class="bb-tech-v2__panel-title">{{ section.settings.panel_title }}</h3>
        {%- endif -%}

        <!-- Panel Subtitle -->
        {%- if section.settings.panel_subtitle != blank -%}
          <p class="bb-tech-v2__panel-sub">{{ section.settings.panel_subtitle }}</p>
        {%- endif -%}

        <!-- Technology Checklist Items -->
        {%- if section.blocks.size > 0 -%}
          <ul class="bb-tech-v2__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'tech_bullet' -%}
                <li class="bb-tech-v2__list-item" {{ block.shopify_attributes }}>
                  <span class="bb-tech-v2__icon">
                    {%- if block.settings.custom_icon != blank -%}
                      <img src="{{ block.settings.custom_icon | image_url: width: 48 }}" alt="" loading="lazy">
                    {%- else -%}
                      {%- if section.settings.bullet_icon_type == 'cross' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                      {%- endif -%}
                    {%- endif -%}
                  </span>
                  <span>{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <!-- Divider -->
        <div class="bb-tech-v2__divider"></div>

        <!-- Footer Highlight Text -->
        {%- if section.settings.footer_text != blank -%}
          <div class="bb-tech-v2__footer-text">{{ section.settings.footer_text }}</div>
        {%- endif -%}

      </div>

    </div>
  </div>
</section>

{%- endunless -%}


{% schema %}
{

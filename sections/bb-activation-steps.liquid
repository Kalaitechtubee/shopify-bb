{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-activation-{{ section.id }} {
    /* Map CSS variables for complete design customization in the editor */
    --act-bg: {{ section.settings.background_color }};
    --act-max-width: {{ section.settings.container_max_width }}px;
    
    --act-badge-bg: {{ section.settings.badge_bg_color }};
    --act-badge-text: {{ section.settings.badge_text_color }};
    --act-badge-border: {{ section.settings.badge_border_color }};
    --act-badge-radius: {{ section.settings.badge_border_radius }}px;
    --act-badge-size: {{ section.settings.badge_font_size }}px;
    --act-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --act-heading-size: {{ section.settings.heading_size_desktop }}px;
    --act-heading-weight: {{ section.settings.heading_weight }};
    --act-heading-color: {{ section.settings.heading_color }};
    --act-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --act-num-bg: {{ section.settings.accent_color }};
    --act-num-color: {{ section.settings.num_text_color }};
    --act-num-size: {{ section.settings.num_circle_size }}px;
    --act-num-radius: {{ section.settings.num_circle_radius }}%;
    --act-num-font-size: {{ section.settings.num_font_size }}px;
    
    --act-divider-width: {{ section.settings.divider_width }}px;
    --act-divider-style: {{ section.settings.divider_style }};
    --act-divider-color: {{ section.settings.divider_color }};
    
    --act-item-padding-y: {{ section.settings.item_padding_y }}px;
    
    --act-title-size: {{ section.settings.title_font_size }}px;
    --act-title-weight: {{ section.settings.title_font_weight }};
    --act-title-color: {{ section.settings.title_color }};
    
    --act-desc-size: {{ section.settings.desc_font_size }}px;
    --act-desc-color: {{ section.settings.desc_color }};
    
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media (min-width: 768px) {
    #bb-activation-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-activation-{{ section.id }} .bb-activation-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-activation-{{ section.id }}"
  class="bb-section bb-activation-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-activation-v2__inner">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-activation-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-activation-v2__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <!-- Steps List -->
      <div class="bb-activation-v2__list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'step' -%}
              <div class="bb-activation-v2__item bb-fade-in" {{ block.shopify_attributes }}>
                <div class="bb-activation-v2__number">
                  {%- if block.settings.custom_icon != blank -%}
                    <img src="{{ block.settings.custom_icon | image_url: width: 64 }}" alt="" loading="lazy">
                  {%- else -%}
                    {{ forloop.index }}
                  {%- endif -%}
                </div>
                <div class="bb-activation-v2__content">
                  {%- if block.settings.title != blank -%}
                    <h3 class="bb-activation-v2__title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="bb-activation-v2__desc">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign steps_meta = product.metafields.custom.activation_steps.value -%}
          {%- if steps_meta != blank -%}
            {%- for item in steps_meta -%}
              <div class="bb-activation-v2__item bb-fade-in">
                <div class="bb-activation-v2__number">
                  {{ forloop.index }}
                </div>
                <div class="bb-activation-v2__content">
                  {%- if item.title != blank -%}<h3 class="bb-activation-v2__title">{{ item.title }}</h3>{%- endif -%}
                  {%- if item.description != blank -%}<p class="bb-activation-v2__desc">{{ item.description }}</p>{%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- endunless -%}

{% schema %}
{
  "name": "BB Activation Steps",
  "tag": "section",
  "class": "bb-section-activation-steps",
  "settings": [
    {
      "type": "header",
      "content": "Section Control"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable Section",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Subheading Badge Options"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Badge Text",
      "default": "HOW IT WORKS"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#FAF0F0"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#622229"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Badge Border Color",
      "default": "#FAF0F0"
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Badge Border Radius",
      "default": 50
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Badge Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_margin_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Badge Margin Bottom",
      "default": 20
    },
    {
      "type": "header",
      "content": "Heading Options"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Four steps to real follicle activation"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Desktop",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Mobile",
      "default": 26
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "default": "800",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ]
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Heading Margin Bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Step List Options"
    },
    {
      "type": "range",
      "id": "item_padding_y",
      "min": 8,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Step Item Vertical Padding",
      "default": 24
    },
    {
      "type": "header",
      "content": "Step Numbers Styling"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Number Circle Background",
      "default": "#622229"
    },
    {
      "type": "color",
      "id": "num_text_color",
      "label": "Number Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "num_circle_size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Number Circle Size",
      "default": 40
    },
    {
      "type": "range",
      "id": "num_circle_radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "%",
      "label": "Number Circle Radius (50% is round)",
      "default": 50
    },
    {
      "type": "range",
      "id": "num_font_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Number Font Size",
      "default": 18
    },
    {
      "type": "header",
      "content": "Dividers Settings"
    },
    {
      "type": "range",
      "id": "divider_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Divider Line Width",
      "default": 1
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Divider Line Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Line Color",
      "default": "#efefef"
    },
    {
      "type": "header",
      "content": "Step Content Styling"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Step Title Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Step Title Font Size",
      "default": 18
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Step Title Font Weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Step Description Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "desc_font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Step Description Font Size",
      "default": 15
    },
    {
      "type": "header",
      "content": "General Spacing"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FAF5F5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top — Desktop",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom — Desktop",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top — Mobile",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom — Mobile",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Cleanse your scalp"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Use a gentle sulphate-free shampoo to remove buildup from the scalp before applying the serum."
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom Step Icon (optional file upload)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BB Activation Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Micro-Stimulation",
            "description": "Tiny dissolvable micro-needles create controlled stimulation on the scalp surface — painless, precise, effective."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Increased Blood Flow",
            "description": "Stimulation boosts oxygen and nutrient delivery to hair roots — waking up the environment growth needs."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Deep Delivery",
            "description": "Actives penetrate beyond the surface level — unlike normal serums that sit on top and wash away."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Follicle Reactivation",
            "description": "Dormant follicles get triggered, initiating a new growth cycle from within."
          }
        }
      ]
    }
  ]
}
{% endschema %}

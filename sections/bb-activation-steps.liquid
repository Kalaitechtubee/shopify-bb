{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}
{%- assign _bb_meta = product.metafields.custom.activation_steps.value -%}
{%- if section.blocks.size == 0 and _bb_meta == blank -%}{%- assign _skip_section = true -%}{%- endif -%}
{%- unless _skip_section -%}

{%- style -%}
  #bb-activation-{{ section.id }} {
    /* Map CSS variables for complete design customization in the editor */
    --act-bg: {{ section.settings.background_color }};
    --act-max-width: {{ section.settings.container_max_width }}px;
    
    --act-badge-bg: {{ section.settings.badge_bg_color }};
    --act-badge-text: {{ section.settings.badge_text_color }};
    --act-badge-border: {{ section.settings.badge_border_color }};
    --act-badge-radius: {{ section.settings.badge_border_radius }}px;
    --act-badge-size: {{ section.settings.badge_font_size }}px;
    --act-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --act-heading-size: {{ section.settings.heading_size_desktop }}px;
    --act-heading-weight: {{ section.settings.heading_weight }};
    --act-heading-color: {{ section.settings.heading_color }};
    --act-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --act-num-bg: {{ section.settings.accent_color }};
    --act-num-color: {{ section.settings.num_text_color }};
    --act-num-size: {{ section.settings.num_circle_size }}px;
    --act-num-radius: {{ section.settings.num_circle_radius }}px;
    --act-num-font-size: {{ section.settings.num_font_size }}px;
    
    --act-divider-width: {{ section.settings.divider_width }}px;
    --act-divider-style: {{ section.settings.divider_style }};
    --act-divider-color: {{ section.settings.divider_color }};
    
    --act-item-padding-y: {{ section.settings.item_padding_y }}px;
    
    --act-title-size: {{ section.settings.title_font_size }}px;
    --act-title-weight: {{ section.settings.title_font_weight }};
    --act-title-color: {{ section.settings.title_color }};
    
    --act-desc-size: {{ section.settings.desc_font_size }}px;
    --act-desc-color: {{ section.settings.desc_color }};
    {%- assign _mx_mob = section.settings.margin_x_mobile | default: 0 -%}
    {%- assign _mx_mob2 = _mx_mob | times: 2 -%}
    padding-top: {{ section.settings.padding_top_mobile | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 0 }}px;
    padding-left: {{ section.settings.padding_left_mobile | default: 0 }}px;
    padding-right: {{ section.settings.padding_right_mobile | default: 0 }}px;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
    margin-left: {{ _mx_mob }}px;
    margin-right: {{ _mx_mob }}px;
    width: calc(100% - {{ _mx_mob2 }}px);
    box-sizing: border-box;
    border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
  }
  @media (min-width: 768px) {
    {%- assign _mx = section.settings.margin_x | default: 0 -%}
    {%- assign _mx2 = _mx | times: 2 -%}
    #bb-activation-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
      padding-left: {{ section.settings.padding_left | default: 0 }}px;
      padding-right: {{ section.settings.padding_right | default: 0 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
      margin-left: {{ _mx }}px;
      margin-right: {{ _mx }}px;
      width: calc(100% - {{ _mx2 }}px);
      box-sizing: border-box;
      border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-activation-{{ section.id }} .bb-activation-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }

  #bb-activation-{{ section.id }} .bb-container {
    max-width: var(--act-max-width);
    width: 100%;
    
    {%- if section.settings.alignment == 'left' -%}
      margin-left: 0;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'center' -%}
      margin-left: auto;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'right' -%}
      margin-left: auto;
      margin-right: 0;
    {%- endif -%}
  }

  #bb-activation-{{ section.id }} .bb-activation-v2__inner {
    max-width: var(--act-max-width);
    width: 100%;
    margin-left: inherit;
    margin-right: inherit;
    
    {%- if section.settings.alignment == 'left' -%}
      align-items: flex-start;
      text-align: left;
    {%- elsif section.settings.alignment == 'center' -%}
      align-items: center;
      text-align: center;
    {%- elsif section.settings.alignment == 'right' -%}
      align-items: flex-end;
      text-align: right;
    {%- endif -%}
  }

  #bb-activation-{{ section.id }} .bb-activation-v2__heading {
    text-align: inherit;
    width: 100%;
    margin-top: 0;
  }

  #bb-activation-{{ section.id }} .bb-activation-v2__list {
    text-align: left;
    border-top: var(--act-divider-width, 1px) var(--act-divider-style, solid) var(--act-divider-color, #efefef);
  }
  #bb-activation-{{ section.id }} .bb-activation-v2__heading {
    font-size: var(--act-heading-size, 72px);
    font-weight: var(--act-heading-weight, 800);
    line-height: 1.05;
    letter-spacing: -2.5px;
    color: var(--act-heading-color, #1A1A1A);
    margin-bottom: var(--act-heading-margin, 48px);
  }
  #bb-activation-{{ section.id }} .bb-activation-v2__heading .bb-heading-maroon {
    color: #622229;
    display: block;
  }
  #bb-activation-{{ section.id }} .bb-activation-v2__number {
    border-radius: var(--act-num-radius, 10px);
    flex-shrink: 0;
    aspect-ratio: 1;
  }
{%- endstyle -%}

<section
  id="bb-activation-{{ section.id }}"
  class="bb-section bb-activation-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-activation-v2__inner">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-activation-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

            <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-activation-v2__heading">
          {%- assign h_raw = section.settings.heading -%}
          {%- assign h_lower = h_raw | downcase -%}
          {%- if h_lower contains "three-layer" or h_lower contains "three layer" or h_lower contains "filtration" -%}
            {%- if h_raw contains "simple" -%}
              {%- assign parts = h_raw | split: "simple" -%}
              {{ parts[0] }}<br><span class="bb-heading-maroon">simple{{ parts[1] }}</span>
            {%- else -%}
              {{ h_raw }}
            {%- endif -%}
          {%- elsif h_lower contains "four steps" -%}
            {%- if h_raw contains "real" -%}
              {%- assign parts = h_raw | split: "real" -%}
              {{ parts[0] }}<br><span class="bb-heading-maroon">real{{ parts[1] }}</span>
            {%- else -%}
              {{ h_raw }}
            {%- endif -%}
          {%- else -%}
            {%- assign h_words = h_raw | split: ' ' -%}
            {%- assign total_words = h_words | size -%}
            {%- if total_words >= 4 -%}
              {%- assign mid = total_words | divided_by: 2 -%}
              {%- assign first_part = h_words | slice: 0, mid | join: ' ' -%}
              {%- assign second_part = h_words | slice: mid, total_words | join: ' ' -%}
              {{ first_part }}<br><span class="bb-heading-maroon">{{ second_part }}</span>
            {%- else -%}
              {{ h_raw }}
            {%- endif -%}
          {%- endif -%}
        </h2>
      {%- endif -%}

      <!-- Steps List -->
      <div class="bb-activation-v2__list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'step' -%}
              <div class="bb-activation-v2__item bb-fade-in" {{ block.shopify_attributes }}>
                <div class="bb-activation-v2__number">
                  {%- if block.settings.custom_icon != blank -%}
                    <img src="{{ block.settings.custom_icon | image_url: width: 64 }}" alt="" loading="lazy">
                  {%- else -%}
                    {{ forloop.index }}
                  {%- endif -%}
                </div>
                <div class="bb-activation-v2__content">
                  {%- if block.settings.title != blank -%}
                    <h3 class="bb-activation-v2__title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="bb-activation-v2__desc">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign steps_meta = product.metafields.custom.activation_steps.value -%}
          {%- if steps_meta != blank -%}
            {%- for item in steps_meta -%}
              <div class="bb-activation-v2__item bb-fade-in">
                <div class="bb-activation-v2__number">
                  {{ forloop.index }}
                </div>
                <div class="bb-activation-v2__content">
                  {%- if item.title != blank -%}<h3 class="bb-activation-v2__title">{{ item.title }}</h3>{%- endif -%}
                  {%- if item.description != blank -%}<p class="bb-activation-v2__desc">{{ item.description }}</p>{%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- endunless -%}{%- comment -%}end _skip_section{%- endcomment -%}
{%- endunless -%}


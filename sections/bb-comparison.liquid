{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-comparison-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    
    /* CSS Variables mapping for complete customization */
    --comp-bg: {{ section.settings.background_color }};
    --comp-max-width: {{ section.settings.container_max_width }}px;
    
    --comp-badge-bg: {{ section.settings.badge_bg_color }};
    --comp-badge-text: {{ section.settings.badge_text_color }};
    --comp-badge-border: {{ section.settings.badge_border_color }};
    --comp-badge-radius: {{ section.settings.badge_border_radius }}px;
    --comp-badge-size: {{ section.settings.badge_font_size }}px;
    --comp-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --comp-heading-size: {{ section.settings.heading_size_desktop }}px;
    --comp-heading-weight: {{ section.settings.heading_weight }};
    --comp-heading-color: {{ section.settings.heading_color }};
    --comp-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --comp-gap: {{ section.settings.grid_gap }}px;
    --comp-card-radius: {{ section.settings.card_border_radius }}px;
    --comp-card-padding: {{ section.settings.card_padding }}px;
    
    /* Left Card */
    --comp-left-bg: {{ section.settings.left_bg_color }};
    --comp-left-border-color: {{ section.settings.left_border_color }};
    --comp-left-title-color: {{ section.settings.left_title_color }};
    --comp-left-title-size: {{ section.settings.left_title_size }}px;
    --comp-left-heading-color: {{ section.settings.left_heading_color }};
    --comp-left-heading-size: {{ section.settings.left_heading_size }}px;
    --comp-left-heading-weight: {{ section.settings.left_heading_weight }};
    --comp-left-desc-size: {{ section.settings.desc_font_size }}px;
    --comp-left-text-color: {{ section.settings.left_text_color }};
    
    /* Right Card */
    --comp-right-bg: {{ section.settings.right_bg_color }};
    --comp-right-border-color: {{ section.settings.right_border_color }};
    --comp-right-title-color: {{ section.settings.right_title_color }};
    --comp-right-title-size: {{ section.settings.right_title_size }}px;
    --comp-right-heading-color: {{ section.settings.right_heading_color }};
    --comp-right-heading-size: {{ section.settings.right_heading_size }}px;
    --comp-right-heading-weight: {{ section.settings.right_heading_weight }};
    --comp-right-desc-size: {{ section.settings.desc_font_size }}px;
    --comp-right-text-color: {{ section.settings.right_text_color }};
    --comp-right-highlight-color: {{ section.settings.right_highlight_color }};
  }
  @media (min-width: 768px) {
    #bb-comparison-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-comparison-{{ section.id }} .bb-comparison-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-comparison-{{ section.id }}"
  class="bb-section bb-comparison-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-comparison-v2__inner bb-text-center">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-comparison-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-comparison-v2__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <!-- Cards Grid -->
      <div class="bb-comparison-v2__cards">
        
        <!-- Left Card (Regular Serums) -->
        <div class="bb-comparison-v2__card bb-comparison-v2__card--left bb-fade-in">
          {%- if section.settings.left_title != blank -%}
            <div class="bb-comparison-v2__card-title--left">
              {%- if section.settings.left_icon != blank -%}
                <span class="bb-comparison-v2__card-title-icon">
                  <img src="{{ section.settings.left_icon | image_url: width: 48 }}" alt="" loading="lazy">
                </span>
              {%- else -%}
                <span class="bb-comparison-v2__card-title-icon" style="color: {{ section.settings.left_title_color }};">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </span>
              {%- endif -%}
              {{ section.settings.left_title }}
            </div>
          {%- endif -%}
          {%- if section.settings.left_header != blank -%}
            <h3 class="bb-comparison-v2__card-header--left">{{ section.settings.left_header }}</h3>
          {%- endif -%}
          {%- if section.settings.left_desc != blank -%}
            <div class="bb-comparison-v2__card-desc--left">{{ section.settings.left_desc }}</div>
          {%- endif -%}
        </div>

        <!-- Right Card (Boost & Bloom) -->
        <div class="bb-comparison-v2__card bb-comparison-v2__card--right bb-fade-in">
          {%- if section.settings.right_title != blank -%}
            <div class="bb-comparison-v2__card-title--right">
              {%- if section.settings.right_icon != blank -%}
                <span class="bb-comparison-v2__card-title-icon">
                  <img src="{{ section.settings.right_icon | image_url: width: 48 }}" alt="" loading="lazy">
                </span>
              {%- else -%}
                <span class="bb-comparison-v2__card-title-icon" style="color: {{ section.settings.right_title_color }};">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
              {%- endif -%}
              {{ section.settings.right_title }}
            </div>
          {%- endif -%}
          {%- if section.settings.right_header != blank -%}
            <h3 class="bb-comparison-v2__card-header--right">{{ section.settings.right_header }}</h3>
          {%- endif -%}
          {%- if section.settings.right_desc != blank -%}
            <div class="bb-comparison-v2__card-desc--right">{{ section.settings.right_desc }}</div>
          {%- endif -%}
        </div>

      </div>

    </div>
  </div>
</section>

{%- endunless -%}

{% schema %}
{

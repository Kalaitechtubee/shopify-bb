{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  {%- assign left_bg = section.settings.left_bg_color -%}
  {%- assign left_border = section.settings.left_border_color -%}
  {%- assign right_bg = section.settings.right_bg_color -%}
  {%- assign right_border = section.settings.right_border_color -%}
  {%- assign right_title = section.settings.right_title_color -%}
  {%- assign right_heading = section.settings.right_heading_color -%}
  {%- assign right_text = section.settings.right_text_color -%}
  {%- assign right_highlight = section.settings.right_highlight_color -%}

  {%- if left_bg == '#FAF0F0' or left_bg == blank or left_bg == 'rgba(0,0,0,0)' -%}
    {%- if left_border == '#FAF0F0' or left_border == '#faf0f0' or left_border == blank or left_border == 'rgba(0,0,0,0)' -%}
      {%- assign left_border = '#E4A1A9' -%}
    {%- endif -%}
  {%- endif -%}

  {%- if right_bg == '#000000' or right_bg == blank or right_bg == 'rgba(0,0,0,0)' -%}
    {%- assign right_bg = '#FFFFFF' -%}
  {%- endif -%}
  {%- if right_border == '#000000' or right_border == blank or right_border == 'rgba(0,0,0,0)' -%}
    {%- assign right_border = '#A3FE01' -%}
  {%- endif -%}
  {%- if right_title == '#FF808B' or right_title == '#ff808b' or right_title == blank or right_title == 'rgba(0,0,0,0)' -%}
    {%- assign right_title = '#24B14C' -%}
  {%- endif -%}
  {%- if right_heading == '#ffffff' or right_heading == '#FFFFFF' or right_heading == blank or right_heading == 'rgba(0,0,0,0)' -%}
    {%- assign right_heading = '#17123B' -%}
  {%- endif -%}
  {%- if right_text == 'rgba(255, 255, 255, 0.85)' or right_text == 'rgba(255,255,255,0.85)' or right_text == blank or right_text == 'rgba(0,0,0,0)' -%}
    {%- assign right_text = '#17123B' -%}
  {%- endif -%}
  {%- if right_highlight == '#A3FE01' or right_highlight == '#a3fe01' or right_highlight == blank or right_highlight == 'rgba(0,0,0,0)' -%}
    {%- assign right_highlight = '#24B14C' -%}
  {%- endif -%}

  #bb-comparison-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 0 }}px;
    padding-left: {{ section.settings.padding_left_mobile | default: 0 }}px;
    padding-right: {{ section.settings.padding_right_mobile | default: 0 }}px;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
    margin-left: {{ section.settings.margin_x_mobile | default: 0 }}px;
    margin-right: {{ section.settings.margin_x_mobile | default: 0 }}px;
    {%- assign _mx_mob2 = section.settings.margin_x_mobile | default: 0 | times: 2 -%}
    width: calc(100% - {{ _mx_mob2 }}px);
    box-sizing: border-box;
    border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
    
    /* CSS Variables mapping for complete customization */
    --comp-bg: {{ section.settings.background_color }};
    --comp-max-width: {{ section.settings.container_max_width | default: 1200 }}px;
    
    --comp-badge-bg: {{ section.settings.badge_bg_color }};
    --comp-badge-text: {{ section.settings.badge_text_color }};
    --comp-badge-border: {{ section.settings.badge_border_color }};
    --comp-badge-radius: {{ section.settings.badge_border_radius | default: 50 }}px;
    --comp-badge-size: {{ section.settings.badge_font_size | default: 12 }}px;
    --comp-badge-margin: {{ section.settings.badge_margin_bottom | default: 20 }}px;
    
    --comp-heading-size: {{ section.settings.heading_size_desktop | default: 36 }}px;
    --comp-heading-weight: {{ section.settings.heading_weight }};
    --comp-heading-color: {{ section.settings.heading_color }};
    --comp-heading-margin: {{ section.settings.heading_margin_bottom | default: 32 }}px;
    
    --comp-gap: {{ section.settings.grid_gap | default: 24 }}px;
    --comp-card-radius: {{ section.settings.card_border_radius | default: 16 }}px;
    --comp-card-padding: {{ section.settings.card_padding | default: 32 }}px;
    
    /* Left Card */
    --comp-left-bg: {{ left_bg }};
    --comp-left-border-color: {{ left_border }};
    --comp-left-title-color: {{ section.settings.left_title_color }};
    --comp-left-title-size: {{ section.settings.left_title_size | default: 13 }}px;
    --comp-left-heading-color: {{ section.settings.left_heading_color }};
    --comp-left-heading-size: {{ section.settings.left_heading_size | default: 22 }}px;
    --comp-left-heading-weight: {{ section.settings.left_heading_weight }};
    --comp-left-desc-size: {{ section.settings.desc_font_size | default: 15 }}px;
    --comp-left-text-color: {{ section.settings.left_text_color }};
    
    /* Right Card */
    --comp-right-bg: {{ right_bg }};
    --comp-right-border-color: {{ right_border }};
    --comp-right-title-color: {{ right_title }};
    --comp-right-title-size: {{ section.settings.right_title_size | default: 13 }}px;
    --comp-right-heading-color: {{ right_heading }};
    --comp-right-heading-size: {{ section.settings.right_heading_size | default: 22 }}px;
    --comp-right-heading-weight: {{ section.settings.right_heading_weight }};
    --comp-right-desc-size: {{ section.settings.desc_font_size | default: 15 }}px;
    --comp-right-text-color: {{ right_text }};
    --comp-right-highlight-color: {{ right_highlight }};
  }
  @media (min-width: 768px) {
    #bb-comparison-{{ section.id }} {
      {%- assign _mx = section.settings.margin_x | default: 0 -%}
      {%- assign _mx2 = _mx | times: 2 -%}
      padding-top: {{ section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
      padding-left: {{ section.settings.padding_left | default: 0 }}px;
      padding-right: {{ section.settings.padding_right | default: 0 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
      margin-left: {{ _mx }}px;
      margin-right: {{ _mx }}px;
      width: calc(100% - {{ _mx2 }}px);
      box-sizing: border-box;
      border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-comparison-{{ section.id }} .bb-comparison-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }

  #bb-comparison-{{ section.id }} .bb-container {
    max-width: var(--comp-max-width);
    width: 100%;
    
    {%- if section.settings.alignment == 'left' -%}
      margin-left: 0;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'center' -%}
      margin-left: auto;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'right' -%}
      margin-left: auto;
      margin-right: 0;
    {%- endif -%}
  }


  #bb-comparison-{{ section.id }} .bb-comparison-v2__inner {
    max-width: var(--comp-max-width);
    width: 100%;
    margin-left: inherit;
    margin-right: inherit;
    
    {%- if section.settings.alignment == 'left' -%}
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    {%- elsif section.settings.alignment == 'center' -%}
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    {%- elsif section.settings.alignment == 'right' -%}
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      text-align: right;
    {%- endif -%}
  }

  #bb-comparison-{{ section.id }} .bb-comparison-v2__heading {
    text-align: inherit;
    width: 100%;
    margin-top: 0;
    line-height: 1.0;
    letter-spacing: -2px;
    color: #17123B;
  }
  #bb-comparison-{{ section.id }} .bb-comparison-v2__heading .bb-heading-maroon {
    color: #6B2430;
    display: block;
  }

  #bb-comparison-{{ section.id }} .bb-comparison-v2__cards {
    text-align: left;
  }

  #bb-comparison-{{ section.id }} .bb-comparison-v2__card-title--right {
    color: var(--comp-right-heading-color, #17123B);
  }
{%- endstyle -%}

<section
  id="bb-comparison-{{ section.id }}"
  class="bb-section bb-comparison-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-comparison-v2__inner">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-comparison-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-comparison-v2__heading">
          {%- assign h_lower = section.settings.heading | downcase -%}
          {%- if h_lower contains "why regular" and h_lower contains "failing you" -%}
            {%- if h_lower contains " keep " -%}
              {%- assign first_part = section.settings.heading | split: " keep " | first -%}
              {%- assign second_part = section.settings.heading | split: first_part | last -%}
              {{ first_part }}<br><span class="bb-heading-maroon">{{ second_part | strip }}</span>
            {%- else -%}
              {{ section.settings.heading }}
            {%- endif -%}
          {%- else -%}
            {{ section.settings.heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}

      <!-- Cards Grid -->
      <div class="bb-comparison-v2__cards">
        
        {%- assign left_clean_title = section.settings.left_title | replace: "✕", "" | replace: "✖", "" | replace: "✕", "" | replace: "x ", "" | replace: "X ", "" | strip -%}
        {%- assign right_clean_title = section.settings.right_title | replace: "✓", "" | replace: "✔", "" | replace: "✓", "" | replace: "v ", "" | replace: "V ", "" | strip -%}

        <!-- Left Card (Regular Serums) -->
        <div class="bb-comparison-v2__card bb-comparison-v2__card--left bb-fade-in">
          {%- if section.settings.left_title != blank -%}
            <div class="bb-comparison-v2__card-title--left">
              {%- if section.settings.left_icon != blank -%}
                <span class="bb-comparison-v2__card-title-icon">
                  <img src="{{ section.settings.left_icon | image_url: width: 48 }}" alt="" loading="lazy">
                </span>
              {%- else -%}
                <span class="bb-comparison-v2__card-title-icon" style="color: var(--comp-left-title-color);">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </span>
              {%- endif -%}
              {{ left_clean_title }}
            </div>
          {%- endif -%}
          {%- if section.settings.left_header != blank -%}
            <h3 class="bb-comparison-v2__card-header--left">{{ section.settings.left_header }}</h3>
          {%- endif -%}
          {%- if section.settings.left_desc != blank -%}
            <div class="bb-comparison-v2__card-desc--left">{{ section.settings.left_desc }}</div>
          {%- endif -%}
        </div>

        <!-- Right Card (Boost & Bloom) -->
        <div class="bb-comparison-v2__card bb-comparison-v2__card--right bb-fade-in">
          {%- if section.settings.right_title != blank -%}
            <div class="bb-comparison-v2__card-title--right">
              {%- if section.settings.right_icon != blank -%}
                <span class="bb-comparison-v2__card-title-icon">
                  <img src="{{ section.settings.right_icon | image_url: width: 48 }}" alt="" loading="lazy">
                </span>
              {%- else -%}
                <span class="bb-comparison-v2__card-title-icon" style="color: var(--comp-right-title-color);">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
              {%- endif -%}
              {{ right_clean_title }}
            </div>
          {%- endif -%}
          {%- if section.settings.right_header != blank -%}
            <h3 class="bb-comparison-v2__card-header--right">{{ section.settings.right_header }}</h3>
          {%- endif -%}
          {%- if section.settings.right_desc != blank -%}
            <div class="bb-comparison-v2__card-desc--right">{{ section.settings.right_desc }}</div>
          {%- endif -%}
        </div>

      </div>

    </div>
  </div>
</section>
{%- endunless -%}

{% schema %}
{
  "name": "BB Comparison Cards",
  "tag": "section",
  "class": "bb-section-comparison",
  "settings": [
    {
      "type": "header",
      "content": "Section Control"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable Section",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 400,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1600
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Section Alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Subheading Badge Options"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Badge Text",
      "default": "WHAT MAKES IT DIFFERENT"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#FAF0F0"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#622229"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Badge Border Color",
      "default": "#FAF0F0"
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Badge Border Radius",
      "default": 50
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Badge Font Size",
      "default": 10
    },
    {

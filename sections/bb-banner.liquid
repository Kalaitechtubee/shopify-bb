{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-banner-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  #bb-banner-{{ section.id }} .bb-banner__overlay {
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
  #bb-banner-{{ section.id }} .bb-banner__heading { color: {{ section.settings.heading_color }}; }
  #bb-banner-{{ section.id }} .bb-banner__sub     { color: {{ section.settings.text_color }}; }
  @media (min-width: 768px) {
    #bb-banner-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-banner-{{ section.id }}"
  class="bb-section bb-banner {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <!-- Background -->
  <div class="bb-banner__bg">
    {%- if section.settings.background_image != blank -%}
      <img
        src="{{ section.settings.background_image | image_url: width: 1800 }}"
        srcset="{{ section.settings.background_image | image_url: width: 900 }} 900w, {{ section.settings.background_image | image_url: width: 1440 }} 1440w, {{ section.settings.background_image | image_url: width: 1800 }} 1800w"
        sizes="100vw"
        alt="{{ section.settings.background_image.alt | escape | default: section.settings.heading | escape }}"
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
        loading="lazy"
      >
    {%- endif -%}
  </div>
  <div class="bb-banner__overlay"></div>

  <!-- Content -->
  <div class="bb-container">
    <div class="bb-banner__content bb-fade-in">
      {%- if section.settings.subheading != blank -%}
        <p class="bb-subheading bb-subheading--accent bb-mb-16">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-banner__heading bb-mb-16">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="bb-banner__sub bb-mb-32">{{ section.settings.subtext }}</p>
      {%- endif -%}

      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        {%- if section.settings.button_text != blank -%}
          <a
            href="{{ section.settings.button_url | default: '#' }}"
            class="bb-btn bb-btn--accent bb-btn--lg"
            style="color:{{ section.settings.button_text_color }};"
          >
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_button_text != blank -%}
          <a
            href="{{ section.settings.secondary_button_url | default: '#' }}"
            class="bb-btn bb-btn--outline-white bb-btn--lg"
          >
            {{ section.settings.secondary_button_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{%- endunless -%}

{% schema %}
{
  "name": "BB Banner",
  "tag": "section",
  "class": "bb-section-banner",
  "settings": [
    {
      "type": "header",
      "content": "Section Control"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable Section",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Transform your shower. Transform your hair."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join 50,000+ customers who've made the switch to cleaner shower water."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Primary Button Text",
      "default": "Shop Splash Filter"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Primary Button URL"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Primary Button Text Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Secondary Button URL"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#622229"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 85
    },
    {
      "type": "header",
      "content": "Text Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subtext Color",
      "default": "#eeeeee"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Desktop",
      "default": 56
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading Size — Mobile",
      "default": 32
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 240,
      "step": 8,
      "unit": "px",
      "label": "Padding Top — Desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 240,
      "step": 8,
      "unit": "px",
      "label": "Padding Bottom — Desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Top — Mobile",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Bottom — Mobile",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "BB Banner"
    }
  ]
}
{% endschema %}

{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}
{%- assign _bb_meta = product.metafields.custom.problems.value -%}
{%- if section.blocks.size == 0 and _bb_meta == blank -%}{%- assign _skip_section = true -%}{%- endif -%}
{%- unless _skip_section -%}

{%- style -%}
  {%- assign bg_color = section.settings.background_color -%}
  {%- if bg_color == '#FAF5F5' or bg_color == '#ffffff' or bg_color == '#FFFFFF' or bg_color == blank -%}
    {%- assign bg_color = '#FAF0F0' -%}
  {%- endif -%}

  #bb-recognise-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 0 }}px;
    padding-left: {{ section.settings.padding_left_mobile | default: 0 }}px;
    padding-right: {{ section.settings.padding_right_mobile | default: 0 }}px;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
    
    /* CSS Variables mapping for complete customization */
    --rec-bg: {{ bg_color }};
    --rec-max-width: {{ section.settings.container_max_width }}px;
    
    --rec-badge-bg: {{ section.settings.badge_bg_color }};
    --rec-badge-text: {{ section.settings.badge_text_color }};
    --rec-badge-border: {{ section.settings.badge_border_color }};
    --rec-badge-radius: {{ section.settings.badge_border_radius }}px;
    --rec-badge-size: {{ section.settings.badge_font_size }}px;
    --rec-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --rec-heading-size: {{ section.settings.heading_size_desktop }}px;
    --rec-heading-weight: {{ section.settings.heading_weight }};
    --rec-heading-color: {{ section.settings.heading_color }};
    --rec-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --rec-cols-desktop: {{ section.settings.columns_desktop }};
    --rec-gap: {{ section.settings.grid_gap }}px;
    
    --rec-card-bg: {{ section.settings.card_bg_color }};
    --rec-card-border: {{ section.settings.card_border_color }};
    --rec-card-border-hover: {{ section.settings.card_border_hover_color }};
    --rec-card-radius: {{ section.settings.card_border_radius }}px;
    --rec-card-padding: {{ section.settings.card_padding }}px;
    
    --rec-icon-size: {{ section.settings.bullet_icon_size }}px;
    --rec-bullet-color: {{ section.settings.bullet_color }};
    
    --rec-text-size: {{ section.settings.card_text_size }}px;
    --rec-text-weight: {{ section.settings.card_text_weight }}px;
    --rec-text-color: {{ section.settings.text_color }};
  }
  @media (min-width: 768px) {
    #bb-recognise-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
      padding-left: {{ section.settings.padding_left | default: 0 }}px;
      padding-right: {{ section.settings.padding_right | default: 0 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
      {%- unless section.settings.full_width -%}
        max-width: var(--page-width, 1200px);
        margin-left: auto;
        margin-right: auto;
      {%- endunless -%}
    }
  }
  @media (max-width: 768px) {
    #bb-recognise-{{ section.id }} .bb-recognise-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }

  #bb-recognise-{{ section.id }} .bb-container {
    max-width: var(--rec-max-width);
    width: 100%;
    
    {%- if section.settings.alignment == 'left' -%}
      margin-left: 0;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'center' -%}
      margin-left: auto;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'right' -%}
      margin-left: auto;
      margin-right: 0;
    {%- endif -%}
  }

  #bb-recognise-{{ section.id }} .bb-recognise-v2__inner {
    max-width: var(--rec-max-width);
    width: 100%;
    margin-left: inherit;
    margin-right: inherit;
    
    {%- if section.settings.alignment == 'left' -%}
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    {%- elsif section.settings.alignment == 'center' -%}
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    {%- elsif section.settings.alignment == 'right' -%}
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      text-align: right;
    {%- endif -%}
  }

  #bb-recognise-{{ section.id }} .bb-recognise-v2__heading {
    text-align: inherit;
    width: 100%;
    margin-top: 0;
    line-height: 1.0;
    letter-spacing: -2px;
    color: #17123B;
  }
  #bb-recognise-{{ section.id }} .bb-recognise-v2__heading .bb-heading-maroon {
    color: #6B2430;
    display: block;
  }

  #bb-recognise-{{ section.id }} .bb-recognise-v2__grid {
    text-align: left;
  }
  #bb-recognise-{{ section.id }} .bb-recognise-v2__card:hover {
    border-color: var(--rec-card-border-hover);
  }
{%- endstyle -%}

<section
  id="bb-recognise-{{ section.id }}"
  class="bb-section bb-recognise-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-recognise-v2__inner">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-recognise-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-recognise-v2__heading">
          {%- assign h_lower = section.settings.heading | downcase -%}
          {%- if h_lower contains "perfect if" and h_lower contains "recognise" -%}
            {%- if h_lower contains " recognise " -%}
              {%- assign first_part = section.settings.heading | split: " recognise " | first -%}
              {%- assign second_part = section.settings.heading | split: first_part | last -%}
              {{ first_part }}<br><span class="bb-heading-maroon">{{ second_part | strip }}</span>
            {%- else -%}
              {{ section.settings.heading }}
            {%- endif -%}
          {%- else -%}
            {{ section.settings.heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}

      <!-- Grid -->
      <div class="bb-recognise-v2__grid">
        {%- if section.settings.use_default_content -%}
          <!-- 6 Default Cards to match reference image -->
          <div class="bb-recognise-v2__card bb-fade-in">
            <span class="bb-recognise-v2__card-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
            </span>
            <p class="bb-recognise-v2__card-text">Hair fall due to stress, water, or lifestyle</p>
          </div>
          <div class="bb-recognise-v2__card bb-fade-in">
            <span class="bb-recognise-v2__card-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
            </span>
            <p class="bb-recognise-v2__card-text">Thinning hairline or widening partition</p>
          </div>
          <div class="bb-recognise-v2__card bb-fade-in">
            <span class="bb-recognise-v2__card-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
            </span>
            <p class="bb-recognise-v2__card-text">Slow or no regrowth despite treatments</p>
          </div>
          <div class="bb-recognise-v2__card bb-fade-in">
            <span class="bb-recognise-v2__card-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
            </span>
            <p class="bb-recognise-v2__card-text">Weak roots or frequent breakage</p>
          </div>
          <div class="bb-recognise-v2__card bb-fade-in">
            <span class="bb-recognise-v2__card-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
            </span>
            <p class="bb-recognise-v2__card-text">Patchy hair density</p>
          </div>
          <div class="bb-recognise-v2__card bb-fade-in">
            <span class="bb-recognise-v2__card-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
            </span>
            <p class="bb-recognise-v2__card-text">Undergoing or planning hair treatments</p>
          </div>
        {%- else -%}
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'problem' -%}
                <div class="bb-recognise-v2__card bb-fade-in" {{ block.shopify_attributes }}>
                  <span class="bb-recognise-v2__card-icon">
                    {%- if block.settings.custom_icon != blank -%}
                      <img src="{{ block.settings.custom_icon | image_url: width: 48 }}" alt="" loading="lazy">
                    {%- else -%}
                      {%- if section.settings.bullet_icon_type == 'checkmark' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                      {%- elsif section.settings.bullet_icon_type == 'cross' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      {%- elsif section.settings.bullet_icon_type == 'dot' -%}
                        <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
                      {%- endif -%}
                    {%- endif -%}
                  </span>
                  <p class="bb-recognise-v2__card-text">{{ block.settings.text }}</p>
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- assign probs_meta = product.metafields.custom.problem_items.value -%}
            {%- if probs_meta != blank -%}
              {%- for item in probs_meta -%}
                <div class="bb-recognise-v2__card bb-fade-in">
                  <span class="bb-recognise-v2__card-icon">
                    {%- if section.settings.bullet_icon_type == 'dot' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
                    {%- endif -%}
                  </span>
                  <p class="bb-recognise-v2__card-text">{{ item }}</p>
                </div>
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- endunless -%}{%- comment -%}end _skip_section{%- endcomment -%}
{%- endunless -%}


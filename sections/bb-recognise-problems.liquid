      "label": "Columns — Desktop",
      "default": 2
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Grid Gap",
      "default": 16
    },
    {
      "type": "header",
      "content": "Card Options"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",

      "default": 50
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Badge Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_margin_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Badge Margin Bottom",
      "default": 20
    },
    {
      "type": "header",

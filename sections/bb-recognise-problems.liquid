{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-recognise-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    
    /* CSS Variables mapping for complete customization */
    --rec-bg: {{ section.settings.background_color }};
    --rec-max-width: {{ section.settings.container_max_width }}px;
    
    --rec-badge-bg: {{ section.settings.badge_bg_color }};
    --rec-badge-text: {{ section.settings.badge_text_color }};
    --rec-badge-border: {{ section.settings.badge_border_color }};
    --rec-badge-radius: {{ section.settings.badge_border_radius }}px;
    --rec-badge-size: {{ section.settings.badge_font_size }}px;
    --rec-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --rec-heading-size: {{ section.settings.heading_size_desktop }}px;
    --rec-heading-weight: {{ section.settings.heading_weight }};
    --rec-heading-color: {{ section.settings.heading_color }};
    --rec-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --rec-cols-desktop: {{ section.settings.columns_desktop }};
    --rec-gap: {{ section.settings.grid_gap }}px;
    
    --rec-card-bg: {{ section.settings.card_bg_color }};
    --rec-card-border: {{ section.settings.card_border_color }};
    --rec-card-radius: {{ section.settings.card_border_radius }}px;
    --rec-card-padding: {{ section.settings.card_padding }}px;
    
    --rec-icon-size: {{ section.settings.bullet_icon_size }}px;
    --rec-bullet-color: {{ section.settings.bullet_color }};
    
    --rec-text-size: {{ section.settings.card_text_size }}px;
    --rec-text-weight: {{ section.settings.card_text_weight }};
    --rec-text-color: {{ section.settings.text_color }};
  }
  @media (min-width: 768px) {
    #bb-recognise-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-recognise-{{ section.id }} .bb-recognise-v2__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }
{%- endstyle -%}

<section
  id="bb-recognise-{{ section.id }}"
  class="bb-section bb-recognise-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-recognise-v2__inner bb-text-center">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-recognise-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-recognise-v2__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <!-- Grid -->
      <div class="bb-recognise-v2__grid">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'problem' -%}
              <div class="bb-recognise-v2__card bb-fade-in" {{ block.shopify_attributes }}>
                <span class="bb-recognise-v2__card-icon">
                  {%- if block.settings.custom_icon != blank -%}
                    <img src="{{ block.settings.custom_icon | image_url: width: 48 }}" alt="" loading="lazy">
                  {%- else -%}
                    {%- if section.settings.bullet_icon_type == 'checkmark' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {%- elsif section.settings.bullet_icon_type == 'cross' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    {%- elsif section.settings.bullet_icon_type == 'dot' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
                    {%- endif -%}
                  {%- endif -%}
                </span>
                <p class="bb-recognise-v2__card-text">{{ block.settings.text }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign probs_meta = product.metafields.custom.problem_items.value -%}
          {%- if probs_meta != blank -%}
            {%- for item in probs_meta -%}
              <div class="bb-recognise-v2__card bb-fade-in">
                <span class="bb-recognise-v2__card-icon">
                  {%- if section.settings.bullet_icon_type == 'dot' -%}
                    <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
                  {%- endif -%}
                </span>
                <p class="bb-recognise-v2__card-text">{{ item }}</p>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- endunless -%}

{% schema %}
{
  "name": "BB Recognise Problems",
  "tag": "section",
  "class": "bb-section-recognise",
  "settings": [
    {
      "type": "header",

      "step": 1,
      "unit": "px",
      "label": "Bullet Icon Size",
      "default": 10
    },
    {
      "type": "header",
      "content": "Card Typography"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Card Text Color",

{%- if p_content != blank -%}
<section
  id="bb-policy-{{ section.id }}"
  class="bb-section bb-policy {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    {%- if p_title != blank -%}
      <h1 class="bb-policy__title">{{ p_title }}</h1>
    {%- endif -%}


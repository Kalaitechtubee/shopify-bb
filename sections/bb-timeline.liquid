{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}
{%- assign _bb_meta = product.metafields.custom.timeline_items.value -%}
{%- assign _has_items = false -%}
{%- for i in (1..4) -%}
  {%- capture week_id -%}item_{{ i }}_week{%- endcapture -%}
  {%- assign week_val = section.settings[week_id] -%}
  {%- if week_val != blank -%}
    {%- assign _has_items = true -%}
  {%- endif -%}
{%- endfor -%}
{%- if _has_items == false and _bb_meta == blank -%}{%- assign _skip_section = true -%}{%- endif -%}
{%- unless _skip_section -%}

{%- style -%}
  #bb-timeline-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-left: {{ section.settings.margin_x_mobile | default: 0 }}px;
    margin-right: {{ section.settings.margin_x_mobile | default: 0 }}px;
    {%- assign _mx_mob2 = section.settings.margin_x_mobile | default: 0 | times: 2 -%}
    width: calc(100% - {{ _mx_mob2 }}px);
    box-sizing: border-box;
    border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
    
    /* CSS Variables mapping for complete customization */
    --t-bg: {{ section.settings.background_color }};
    --t-max-width: {{ section.settings.container_max_width }}px;
    
    --t-badge-bg: {{ section.settings.badge_bg_color }};
    --t-badge-text: {{ section.settings.badge_text_color }};
    --t-badge-border: {{ section.settings.badge_border_color }};
    --t-badge-radius: {{ section.settings.badge_border_radius }}px;
    --t-badge-size: {{ section.settings.badge_font_size }}px;
    --t-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --t-heading-size: {{ section.settings.heading_size_desktop }}px;
    --t-heading-weight: {{ section.settings.heading_weight }};
    --t-heading-color: {{ section.settings.heading_color }};
    --t-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --t-padding-y: {{ section.settings.item_padding_y }}px;
    
    --t-divider-width: {{ section.settings.divider_width }}px;
    --t-divider-style: {{ section.settings.divider_style }};
    --t-divider-color: {{ section.settings.divider_color }};
    
    --t-text-size: {{ section.settings.card_text_size }}px;
    --t-text-color: {{ section.settings.text_color }};
    --t-highlight-color: {{ section.settings.highlight_color }};

    /* Pill (Week Label) common styling */
    --t-pill-bg: {{ section.settings.pill_bg_color }};
    --t-pill-text: {{ section.settings.pill_text_color }};
    --t-pill-radius: {{ section.settings.pill_radius }}px;
    --t-pill-size: {{ section.settings.pill_font_size }}px;

    /* Title common styling */
    --t-title-color: {{ section.settings.item_title_color }};
    --t-title-size: {{ section.settings.item_title_size }}px;
    --t-title-weight: {{ section.settings.item_title_weight }};

    /* Description common styling */
    --t-desc-color: {{ section.settings.item_desc_color }};
    --t-desc-size: {{ section.settings.item_desc_size }}px;
  }
  @media (min-width: 768px) {
    #bb-timeline-{{ section.id }} {
      {%- assign _mx = section.settings.margin_x | default: 0 -%}
      {%- assign _mx2 = _mx | times: 2 -%}
      padding-top: {{ section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
      padding-left: {{ section.settings.padding_left | default: 0 }}px;
      padding-right: {{ section.settings.padding_right | default: 0 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
      margin-left: {{ _mx }}px;
      margin-right: {{ _mx }}px;
      width: calc(100% - {{ _mx2 }}px);
      box-sizing: border-box;
      border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-timeline-{{ section.id }} .bb-timeline-v2__heading {
      font-size: {{ section.settings.heading_size_mobile | default: 32 }}px;
    }
  }

  #bb-timeline-{{ section.id }} .bb-container {
    max-width: var(--t-max-width); width: 100%;
    {%- if section.settings.alignment == 'left' -%}margin-left: 0; margin-right: auto;
    {%- elsif section.settings.alignment == 'center' -%}margin-left: auto; margin-right: auto;
    {%- elsif section.settings.alignment == 'right' -%}margin-left: auto; margin-right: 0;
    {%- endif -%}
  }
  #bb-timeline-{{ section.id }} .bb-timeline-v2__inner {
    display: flex; flex-direction: column;
    {%- if section.settings.alignment == 'left' -%}align-items: flex-start; text-align: left;
    {%- elsif section.settings.alignment == 'center' -%}align-items: center; text-align: center;
    {%- elsif section.settings.alignment == 'right' -%}align-items: flex-end; text-align: right;
    {%- endif -%}
  }
  #bb-timeline-{{ section.id }} .bb-timeline-v2__heading {
    font-size: var(--t-heading-size, 72px);
    font-weight: var(--t-heading-weight, 800);
    line-height: 1.05; letter-spacing: -2.5px;
    color: #17123B; text-align: inherit; width: 100%; margin-top: 0;
    margin-bottom: var(--t-heading-margin, 48px);
  }
  #bb-timeline-{{ section.id }} .bb-heading-maroon {
    color: #6B2430; display: block;
  }
  #bb-timeline-{{ section.id }} .bb-timeline-v2__list {
    text-align: left; width: 100%;
  }
{%- endstyle -%}

<section
  id="bb-timeline-{{ section.id }}"
  class="bb-section bb-timeline-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-timeline-v2__inner">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-timeline-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-timeline-v2__heading">
          {%- assign h_words = section.settings.heading | split: ' ' -%}
          {%- assign total_words = h_words | size -%}
          {%- if total_words >= 2 -%}
            {%- if total_words <= 3 -%}
              {%- assign mid = total_words | minus: 1 -%}
            {%- else -%}
              {%- assign mid = total_words | divided_by: 2 -%}
            {%- endif -%}
            {%- assign first_part = h_words | slice: 0, mid | join: ' ' -%}
            {%- assign second_part = h_words | slice: mid, total_words | join: ' ' -%}
            {{ first_part }}<br><span class="bb-heading-maroon">{{ second_part }}</span>
          {%- else -%}
            {{ section.settings.heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}

      <!-- Timeline List -->
      <ul class="bb-timeline-v2__list">
        {%- if _has_items -%}
          {%- for i in (1..4) -%}
            {%- capture week_id -%}item_{{ i }}_week{%- endcapture -%}
            {%- capture title_id -%}item_{{ i }}_title{%- endcapture -%}
            {%- capture desc_id -%}item_{{ i }}_desc{%- endcapture -%}
            
            {%- assign week_val = section.settings[week_id] -%}
            {%- assign title_val = section.settings[title_id] -%}
            {%- assign desc_val = section.settings[desc_id] -%}
            
            {%- if week_val != blank or title_val != blank or desc_val != blank -%}
              <li class="bb-timeline-v2__item bb-fade-in">
                <!-- Left Capsule / Week Badge -->
                {%- if week_val != blank -%}
                  <span class="bb-timeline-v2__week" style="
                    background-color: var(--t-pill-bg, #FAF0F0);
                    color: var(--t-pill-text, #622229);
                    border-color: var(--t-pill-bg, #FAF0F0);
                    border-radius: var(--t-pill-radius, 50px);
                    font-size: var(--t-pill-size, 12px);
                  ">{{ week_val }}</span>
                {%- endif -%}

                <!-- Right Description -->
                <div class="bb-timeline-v2__content">
                  <p class="bb-timeline-v2__text">
                    {%- if title_val != blank -%}
                      <strong style="
                        color: var(--t-title-color, #1A1A1A);
                        font-size: var(--t-title-size, 16px);
                        font-weight: var(--t-title-weight, 700);
                      ">{{ title_val }}</strong>
                    {%- endif -%}
                    {%- if desc_val != blank -%}
                      <span style="
                        color: var(--t-desc-color, #555555);
                        font-size: var(--t-desc-size, 16px);
                      ">
                        {%- if title_val != blank -%} — {%- endif -%}
                        {{ desc_val }}
                      </span>
                    {%- endif -%}
                  </p>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign timeline_meta = product.metafields.custom.timeline_items.value -%}
          {%- if timeline_meta != blank -%}
            {%- for item in timeline_meta -%}
              <li class="bb-timeline-v2__item bb-fade-in">
                <span class="bb-timeline-v2__week">{{ item.week }}</span>
                <div class="bb-timeline-v2__content">
                  <p class="bb-timeline-v2__text">
                    <strong>{{ item.title }}</strong> — {{ item.description }}
                  </p>
                </div>
              </li>
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      </ul>

    </div>
  </div>
</section>

{%- endunless -%}
{%- endunless -%}

{% schema %}

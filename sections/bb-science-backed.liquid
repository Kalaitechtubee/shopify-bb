{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}
{%- assign _bb_meta = product.metafields.custom.science.value -%}
{%- if section.blocks.size == 0 and _bb_meta == blank -%}{%- assign _skip_section = true -%}{%- endif -%}
{%- unless _skip_section -%}

{%- style -%}
  {%- assign bg_color = section.settings.background_color -%}
  {%- if bg_color == '#FAF5F5' or bg_color == '#ffffff' or bg_color == '#FFFFFF' or bg_color == blank -%}
    {%- assign bg_color = '#FAF0F0' -%}
  {%- endif -%}

  #bb-science-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 0 }}px;
    padding-left: {{ section.settings.padding_left_mobile | default: 0 }}px;
    padding-right: {{ section.settings.padding_right_mobile | default: 0 }}px;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
    
    /* CSS Variables mapping for complete customization */
    --sci-bg: {{ bg_color }};
    --sci-max-width: {{ section.settings.container_max_width | default: 1200 }}px;
    
    --sci-badge-bg: {{ section.settings.badge_bg_color }};
    --sci-badge-text: {{ section.settings.badge_text_color }};
    --sci-badge-border: {{ section.settings.badge_border_color }};
    --sci-badge-radius: {{ section.settings.badge_border_radius | default: 50 }}px;
    --sci-badge-size: {{ section.settings.badge_font_size | default: 12 }}px;
    --sci-badge-margin: {{ section.settings.badge_margin_bottom | default: 20 }}px;
    
    --sci-heading-size: {{ section.settings.heading_size_desktop | default: 36 }}px;
    --sci-heading-weight: {{ section.settings.heading_weight }};
    --sci-heading-color: {{ section.settings.heading_color }};
    --sci-heading-margin: {{ section.settings.heading_margin_bottom | default: 32 }}px;
    
    --sci-gap: {{ section.settings.grid_gap | default: 16 }}px;
    
    --sci-card-bg: {{ section.settings.card_bg_color }};
    --sci-card-border-color: {{ section.settings.card_border_color }};
    --sci-card-radius: {{ section.settings.card_border_radius | default: 12 }}px;
    --sci-card-padding: {{ section.settings.card_padding | default: 20 }}px;
    
    --sci-icon-size: {{ section.settings.icon_size | default: 20 }}px;
    --sci-icon-bg: {{ section.settings.icon_bg_color }};
    --sci-icon-symbol: {{ section.settings.icon_symbol_color }};
    
    --sci-text-size: {{ section.settings.card_text_size | default: 15 }}px;
    --sci-text-weight: {{ section.settings.card_text_weight | default: 500 }}px;
    --sci-text-color: {{ section.settings.text_color }};
  }
  @media (min-width: 768px) {
    #bb-science-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
      padding-left: {{ section.settings.padding_left | default: 0 }}px;
      padding-right: {{ section.settings.padding_right | default: 0 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
      {%- unless section.settings.full_width -%}
        max-width: var(--page-width, 1200px);
        margin-left: auto;
        margin-right: auto;
      {%- endunless -%}
    }
  }
  @media (max-width: 768px) {
    #bb-science-{{ section.id }} .bb-science-v2__heading {
      font-size: {{ section.settings.heading_size_mobile | default: 26 }}px;
    }
  }

  #bb-science-{{ section.id }} .bb-container {
    max-width: var(--sci-max-width);
    width: 100%;
    
    {%- if section.settings.alignment == 'left' -%}
      margin-left: 0;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'center' -%}
      margin-left: auto;
      margin-right: auto;
    {%- elsif section.settings.alignment == 'right' -%}
      margin-left: auto;
      margin-right: 0;
    {%- endif -%}
  }

  #bb-science-{{ section.id }} .bb-science-v2__inner {
    max-width: var(--sci-max-width);
    width: 100%;
    margin-left: inherit;
    margin-right: inherit;
    
    {%- if section.settings.alignment == 'left' -%}
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    {%- elsif section.settings.alignment == 'center' -%}
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    {%- elsif section.settings.alignment == 'right' -%}
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      text-align: right;
    {%- endif -%}
  }

  #bb-science-{{ section.id }} .bb-science-v2__heading {
    text-align: inherit;
    width: 100%;
    margin-top: 0;
    line-height: 1.0;
    letter-spacing: -2px;
    color: #17123B;
  }
  #bb-science-{{ section.id }} .bb-science-v2__heading .bb-heading-maroon {
    color: #6B2430;
  }

  #bb-science-{{ section.id }} .bb-science-v2__list {
    text-align: left;
  }
{%- endstyle -%}

<section
  id="bb-science-{{ section.id }}"
  class="bb-section bb-science-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-science-v2__inner">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-science-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-science-v2__heading">
          {%- assign h_lower = section.settings.heading | downcase -%}
          {%- if h_lower contains "science-backed" and h_lower contains "clinically" -%}
            {%- if h_lower contains ", " -%}
              {%- assign first_part = section.settings.heading | split: ", " | first -%}
              {%- assign second_part = section.settings.heading | split: first_part | last | remove_first: ", " -%}
              {{ first_part }},<br><span class="bb-heading-maroon">{{ second_part | strip }}</span>
            {%- else -%}
              {{ section.settings.heading }}
            {%- endif -%}
          {%- else -%}
            {{ section.settings.heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}

      <!-- Checklist stack -->
      <ul class="bb-science-v2__list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'claim' -%}
              <li class="bb-science-v2__card bb-fade-in" {{ block.shopify_attributes }}>
                <span class="bb-science-v2__check-circle">
                  {%- if block.settings.custom_icon != blank -%}
                    <img src="{{ block.settings.custom_icon | image_url: width: 48 }}" alt="" loading="lazy">
                  {%- else -%}
                    {%- if section.settings.bullet_icon_type == 'checkmark' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {%- elsif section.settings.bullet_icon_type == 'cross' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    {%- elsif section.settings.bullet_icon_type == 'dot' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="6"/></svg>
                    {%- endif -%}
                  {%- endif -%}
                </span>
                <p class="bb-science-v2__text">{{ block.settings.text }}</p>
              </li>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign science_meta = product.metafields.custom.science_claims.value -%}
          {%- if science_meta != blank -%}
            {%- for item in science_meta -%}
              <li class="bb-science-v2__card bb-fade-in">
                <span class="bb-science-v2__check-circle">
                  {%- if section.settings.bullet_icon_type == 'checkmark' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {%- endif -%}
                </span>
                <p class="bb-science-v2__text">{{ item }}</p>
              </li>
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      </ul>

    </div>
  </div>
</section>

{%- endunless -%}{%- comment -%}end _skip_section{%- endcomment -%}
{%- endunless -%}


  ],
  "blocks": [
    {
      "type": "claim",
      "name": "Science Claim",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Claim Text",
          "default": "Backed by science-driven formulation — not marketing claims"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom Bullet Icon (optional file upload)"

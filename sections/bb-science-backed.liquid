          }
        },
        {
          "type": "claim",
          "settings": {
            "text": "High-performance actives only — no fillers"
          }
        },
        {
          "type": "claim",
          "settings": {
            "text": "Designed for visible, real-world results"
          }
        }
      ]
    }
  ]
}
{% endschema %}

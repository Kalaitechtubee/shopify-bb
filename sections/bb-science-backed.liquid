    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Icon Circle Size",
      "default": 20
    },
    {
      "type": "header",
      "content": "Card Typography"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Card Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "card_text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Card Text Font Size",
      "default": 15
    },
    {
      "type": "select",
      "id": "card_text_weight",
      "label": "Card Text Weight",
      "default": "500",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "header",
      "content": "Section Background & Spacing"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#FAF5F5"
    },
    {
      "type": "range",
      "id": "padding_top",

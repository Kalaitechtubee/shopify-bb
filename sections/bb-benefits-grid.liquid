{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}
{%- assign _bb_meta = product.metafields.custom.benefits.value -%}
{%- if section.blocks.size == 0 and _bb_meta == blank -%}{%- assign _skip_section = true -%}{%- endif -%}
{%- unless _skip_section -%}

{%- style -%}
  #bb-benefits-{{ section.id }} {
    {%- assign _mx_mob = section.settings.margin_x_mobile | default: 0 -%}
    {%- assign _mx_mob2 = _mx_mob | times: 2 -%}
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-left: {{ _mx_mob }}px;
    margin-right: {{ _mx_mob }}px;
    width: calc(100% - {{ _mx_mob2 }}px);
    box-sizing: border-box;
    border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
    
    /* CSS Variables mapping for complete customization */
    --results-bg: {{ section.settings.background_color }};
    --results-max-width: {{ section.settings.container_max_width }}px;
    
    --results-badge-bg: {{ section.settings.badge_bg_color }};
    --results-badge-text: {{ section.settings.badge_text_color }};
    --results-badge-border: {{ section.settings.badge_border_color }};
    --results-badge-radius: {{ section.settings.badge_border_radius }}px;
    --results-badge-size: {{ section.settings.badge_font_size }}px;
    --results-badge-margin: {{ section.settings.badge_margin_bottom }}px;
    
    --results-heading-size: {{ section.settings.heading_size_desktop }}px;
    --results-heading-weight: {{ section.settings.heading_weight }};
    --results-heading-color: {{ section.settings.heading_color }};
    --results-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    
    --results-cols-desktop: {{ section.settings.columns_desktop }};
    --results-gap: {{ section.settings.grid_gap }}px;
    
    --results-card-bg: {{ section.settings.card_bg_color }};
    --results-card-border: {{ section.settings.card_border_color }};
    --results-card-border-hover: {{ section.settings.card_border_hover_color | default: '#622229' }};
    --results-card-radius: {{ section.settings.card_border_radius }}px;
    --results-card-padding: {{ section.settings.card_padding }}px;
    
    --results-bullet-size: {{ section.settings.bullet_size }}px;
    --results-bullet-color: {{ section.settings.bullet_color }};
    
    --results-card-title-size: {{ section.settings.card_title_size }}px;
    --results-card-title-weight: {{ section.settings.card_title_weight }};
    --results-card-title-color: {{ section.settings.card_title_color }};
    
    --results-card-desc-size: {{ section.settings.card_desc_size }}px;
    --results-card-desc-color: {{ section.settings.card_desc_color }};
  }
  @media (min-width: 768px) {
    {%- assign _mx = section.settings.margin_x | default: 0 -%}
    {%- assign _mx2 = _mx | times: 2 -%}
    #bb-benefits-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
      padding-left: {{ section.settings.padding_left | default: 0 }}px;
      padding-right: {{ section.settings.padding_right | default: 0 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
      margin-left: {{ _mx }}px;
      margin-right: {{ _mx }}px;
      width: calc(100% - {{ _mx2 }}px);
      box-sizing: border-box;
      border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
    }
  }
  @media (max-width: 768px) {
    #bb-benefits-{{ section.id }} .bb-results-v2__heading {
      font-size: {{ section.settings.heading_size_mobile | default: 32 }}px;
    }
  }
  #bb-benefits-{{ section.id }} .bb-container {
    max-width: var(--results-max-width); width: 100%;
    {%- if section.settings.alignment == 'center' -%}margin-left: auto; margin-right: auto;
    {%- elsif section.settings.alignment == 'right' -%}margin-left: auto; margin-right: 0;
    {%- else -%}margin-left: 0; margin-right: auto;{%- endif -%}
  }
  #bb-benefits-{{ section.id }} .bb-results-v2__inner {
    display: flex; flex-direction: column;
    {%- if section.settings.alignment == 'center' -%}align-items: center; text-align: center;
    {%- elsif section.settings.alignment == 'right' -%}align-items: flex-end; text-align: right;
    {%- else -%}align-items: flex-start; text-align: left;{%- endif -%}
  }
  #bb-benefits-{{ section.id }} .bb-results-v2__heading {
    font-size: var(--results-heading-size, 48px);
    font-weight: var(--results-heading-weight, 800);
    color: var(--results-heading-color, #17123B);
    line-height: 1.1; letter-spacing: -1px;
    text-align: inherit; width: 100%; margin-top: 0;
    margin-bottom: var(--results-heading-margin, 40px);
  }
  #bb-benefits-{{ section.id }} .bb-heading-maroon {
    color: #6B2430; display: block;
  }
{%- endstyle -%}

<section
  id="bb-benefits-{{ section.id }}"
  class="bb-section bb-results-v2 {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-container">
    <div class="bb-results-v2__inner">
      
      <!-- Subheading Badge -->
      {%- if section.settings.subheading != blank -%}
        <div class="bb-results-v2__badge">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <!-- Main Heading -->
      {%- if section.settings.heading != blank -%}
        <h2 class="bb-results-v2__heading">
          {%- assign h_words = section.settings.heading | split: ' ' -%}
          {%- assign total_words = h_words | size -%}
          {%- if total_words >= 2 -%}
            {%- if total_words <= 3 -%}
              {%- assign mid = total_words | minus: 1 -%}
            {%- else -%}
              {%- assign mid = total_words | divided_by: 2 -%}
            {%- endif -%}
            {%- assign first_part = h_words | slice: 0, mid | join: ' ' -%}
            {%- assign second_part = h_words | slice: mid, total_words | join: ' ' -%}
            {{ first_part }}<br><span class="bb-heading-maroon">{{ second_part }}</span>
          {%- else -%}
            {{ section.settings.heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}

      <!-- Benefits Grid (Using Results Grid styles) -->
      <div class="bb-results-v2__grid">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              {%- assign title_color = block.settings.title_color -%}
              {%- assign title_size  = block.settings.title_font_size -%}
              {%- assign desc_color  = block.settings.desc_color -%}
              {%- assign desc_size   = block.settings.desc_font_size -%}
              {%- assign bullet_color = block.settings.bullet_color -%}
              {%- assign bullet_size  = block.settings.bullet_size -%}
              <div class="bb-results-v2__card bb-fade-in" {{ block.shopify_attributes }}>
                
                <!-- Title Row -->
                <div class="bb-results-v2__card-title-wrap">
                  <span class="bb-results-v2__card-bullet" style="
                    {%- if bullet_color != blank -%}background-color: {{ bullet_color }};{%- endif -%}
                    {%- if bullet_size != blank -%}width: {{ bullet_size }}px; height: {{ bullet_size }}px;{%- endif -%}
                  "></span>
                  <h3 class="bb-results-v2__card-title" style="
                    {%- if title_color != blank -%}color: {{ title_color }};{%- endif -%}
                    {%- if title_size != blank -%}font-size: {{ title_size }}px;{%- endif -%}
                  ">{{ block.settings.title }}</h3>
                </div>

                <!-- Description -->
                {%- if block.settings.description != blank -%}
                  <p class="bb-results-v2__card-desc" style="
                    {%- if desc_color != blank -%}color: {{ desc_color }};{%- endif -%}
                    {%- if desc_size != blank -%}font-size: {{ desc_size }}px;{%- endif -%}
                  ">{{ block.settings.description }}</p>
                {%- endif -%}

              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign ben_meta = product.metafields.custom.benefit_items.value -%}
          {%- if ben_meta != blank -%}
            {%- for item in ben_meta -%}
              <div class="bb-results-v2__card bb-fade-in">
                <div class="bb-results-v2__card-title-wrap">
                  <span class="bb-results-v2__card-bullet"></span>
                  <h3 class="bb-results-v2__card-title">{{ item.title }}</h3>
                </div>
                {%- if item.description != blank -%}
                  <p class="bb-results-v2__card-desc">{{ item.description }}</p>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- endunless -%}{%- comment -%}end _skip_section{%- endcomment -%}
{%- endunless -%}


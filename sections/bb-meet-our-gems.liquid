{{ 'bb-theme.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.enable_section == false -%}

{%- style -%}
  #bb-gems-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile | default: 32 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 32 }}px;
    padding-left: {{ section.settings.padding_left_mobile | default: 16 }}px;
    padding-right: {{ section.settings.padding_right_mobile | default: 16 }}px;
    margin-top: {{ section.settings.margin_top_mobile | default: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
    background-color: {{ section.settings.section_bg_color | default: '#FFFFFF' }};
  }

  @media (min-width: 768px) {
    #bb-gems-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | default: 60 }}px;
      padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
      padding-left: {{ section.settings.padding_left | default: 32 }}px;
      padding-right: {{ section.settings.padding_right | default: 32 }}px;
      margin-top: {{ section.settings.margin_top | default: 0 }}px;
      margin-bottom: {{ section.settings.margin_bottom | default: 0 }}px;
    }
  }

  #bb-gems-{{ section.id }} .bb-gems__container {
    {%- if section.settings.full_width == false -%}
      max-width: {{ section.settings.container_max_width | default: 1400 }}px;
      margin-left: auto;
      margin-right: auto;
    {%- endif -%}
    width: 100%;
    box-sizing: border-box;
  }

  /* Section Header */
  #bb-gems-{{ section.id }} .bb-gems__header {
    text-align: center;
    margin-bottom: {{ section.settings.heading_margin_bottom | default: 48 }}px;
  }

  #bb-gems-{{ section.id }} .bb-gems__subheading {
    font-size: {{ section.settings.subheading_size | default: 13 }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: {{ section.settings.subheading_color | default: '#555555' }};
    margin: 0 0 12px 0;
  }

  #bb-gems-{{ section.id }} .bb-gems__heading {
    font-size: {{ section.settings.heading_size_mobile | default: 30 }}px;
    font-weight: {{ section.settings.heading_weight | default: '700' }};
    color: {{ section.settings.heading_color | default: '#000000' }};
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin: 0;
  }

  @media (min-width: 768px) {
    #bb-gems-{{ section.id }} .bb-gems__heading {
      font-size: {{ section.settings.heading_size_desktop | default: 60 }}px;
    }
  }

  #bb-gems-{{ section.id }} .bb-gems__heading em,
  #bb-gems-{{ section.id }} .bb-gems__heading i {
    font-style: italic;
    font-weight: {{ section.settings.heading_accent_weight | default: '700' }};
    color: {{ section.settings.heading_accent_color | default: '#6B2430' }};
  }

  /* Grid Layout */
  #bb-gems-{{ section.id }} .bb-gems__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile | default: 1 }}, 1fr);
    background-color: {{ section.settings.grid_border_color | default: '#70262E' }};
    gap: {{ section.settings.grid_border_width | default: 1 }}px;
    border: {{ section.settings.grid_border_width | default: 1 }}px solid {{ section.settings.grid_border_color | default: '#70262E' }};
    border-radius: {{ section.settings.grid_border_radius | default: 0 }}px;
    overflow: hidden;
  }

  @media (min-width: 600px) {
    #bb-gems-{{ section.id }} .bb-gems__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 992px) {
    #bb-gems-{{ section.id }} .bb-gems__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop | default: 4 }}, 1fr);
    }
  }

  /* Card Item */
  #bb-gems-{{ section.id }} .bb-gems__card {
    display: flex;
    flex-direction: column;
    background-color: #FFFFFF;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    height: 100%;
    {%- if section.settings.enable_custom_card_width -%}
      max-width: {{ section.settings.card_max_width_mobile | default: 280 }}px;
      margin-left: auto;
      margin-right: auto;
      width: 100%;
    {%- endif -%}
  }

  @media (min-width: 768px) {
    #bb-gems-{{ section.id }} .bb-gems__card {
      {%- if section.settings.enable_custom_card_width -%}
        max-width: {{ section.settings.card_max_width_desktop | default: 340 }}px;
      {%- endif -%}
    }
  }

  /* Image Box */
  #bb-gems-{{ section.id }} .bb-gems__image-box {
    position: relative;
    width: 100%;
    {%- if section.settings.enable_custom_image_height -%}
      height: {{ section.settings.image_height_mobile | default: 260 }}px;
    {%- else -%}
      aspect-ratio: {{ section.settings.image_aspect_ratio | default: '1/1' }};
    {%- endif -%}
    background-color: #FAF8F5;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    #bb-gems-{{ section.id }} .bb-gems__image-box {
      {%- if section.settings.enable_custom_image_height -%}
        height: {{ section.settings.image_height_desktop | default: 340 }}px;
      {%- endif -%}
    }
  }

  #bb-gems-{{ section.id }} .bb-gems__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s ease;
  }

  #bb-gems-{{ section.id }} .bb-gems__card:hover .bb-gems__image {
    transform: scale(1.04);
  }

  #bb-gems-{{ section.id }} .bb-gems__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F4F1EA;
    color: #999999;
  }

  /* Card Bottom Banner Strip */
  #bb-gems-{{ section.id }} .bb-gems__banner {
    background-color: {{ section.settings.banner_bg_color | default: '#5C1D24' }};
    padding: {{ section.settings.banner_padding_mobile | default: 20 }}px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-grow: 1;
    transition: background-color 0.2s ease;
  }

  @media (min-width: 768px) {
    #bb-gems-{{ section.id }} .bb-gems__banner {
      padding: {{ section.settings.banner_padding_desktop | default: 28 }}px;
    }
  }

  #bb-gems-{{ section.id }} .bb-gems__card:hover .bb-gems__banner {
    background-color: {{ section.settings.banner_bg_hover | default: '#4A151C' }};
  }

  #bb-gems-{{ section.id }} .bb-gems__title {
    color: {{ section.settings.banner_text_color | default: '#FFFFFF' }};
    font-size: {{ section.settings.banner_text_size_mobile | default: 18 }}px;
    font-weight: {{ section.settings.banner_text_weight | default: '700' }};
    line-height: 1.25;
    margin: 0;
    flex-grow: 1;
  }

  @media (min-width: 768px) {
    #bb-gems-{{ section.id }} .bb-gems__title {
      font-size: {{ section.settings.banner_text_size_desktop | default: 22 }}px;
    }
  }

  #bb-gems-{{ section.id }} .bb-gems__arrow-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    color: {{ section.settings.banner_arrow_color | default: '#A6FF00' }};
    transition: transform 0.3s ease;
  }

  #bb-gems-{{ section.id }} .bb-gems__arrow-icon svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 2.5;
    fill: none;
  }

  #bb-gems-{{ section.id }} .bb-gems__card:hover .bb-gems__arrow-icon {
    transform: translate(3px, -3px);
  }
{%- endstyle -%}

<section
  id="bb-gems-{{ section.id }}"
  class="bb-section bb-meet-our-gems {{ section.settings.custom_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="bb-gems__container">
    
    <!-- Section Header -->
    <div class="bb-gems__header">
      {%- if section.settings.subheading != blank -%}
        <p class="bb-gems__subheading">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag | default: 'h2' }} class="bb-gems__heading">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag | default: 'h2' }}>
      {%- endif -%}
    </div>

    <!-- Gems Cards Grid -->
    <div class="bb-gems__grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link_url | default: '#' }}"
          class="bb-gems__card"
          {{ block.shopify_attributes }}
        >
          <!-- Image Box -->
          <div class="bb-gems__image-box">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1000 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                class="bb-gems__image"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {%- else -%}
              <div class="bb-gems__image-placeholder">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          <!-- Bottom Card Banner Strip -->
          <div class="bb-gems__banner">
            {%- if block.settings.title != blank -%}
              <h3 class="bb-gems__title">
                {{ block.settings.title }}
              </h3>
            {%- endif -%}

            <span class="bb-gems__arrow-icon" style="{% if block.settings.custom_arrow_color != blank %}color: {{ block.settings.custom_arrow_color }};{% endif %}">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

{%- endunless -%}

